<script>
  (function () {
    if (document.documentElement.hasAttribute('data-pc-buy-init')) return;
    document.documentElement.setAttribute('data-pc-buy-init', '');

    var SUCCESS_MS = 1800;

    /* ── Cachad lista över sektioner som ska refreshas ───────────────
       Räknas ut EN gång när scriptet laddas. Sektionerna ändras inte
       under sidans livstid, så vi slipper scanna DOM vid varje klick. */
    var cachedSectionIds = null;

    function getCartSectionIds() {
      if (cachedSectionIds !== null) return cachedSectionIds;

      var ids = [];
      var seen = {};

      // Sektioner vars ID innehåller "cart" eller "header"
      var sections = document.querySelectorAll('[id^="shopify-section-"]');
      for (var i = 0; i < sections.length; i++) {
        var id = sections[i].id.replace('shopify-section-', '');
        var lower = id.toLowerCase();
        if ((lower.indexOf('cart') > -1 || lower.indexOf('header') > -1) && !seen[id]) {
          seen[id] = true;
          ids.push(id);
        }
      }

      // Sektioner via cart-element (för säkerhets skull, om någon
      // sektion inte har "cart" eller "header" i sitt namn)
      var cartEls = document.querySelectorAll(
        '[data-cart-count],.cart-count-bubble,.cart-count,.count-bubble,#cart-icon-bubble,cart-count,.header__cart-count'
      );
      for (var j = 0; j < cartEls.length; j++) {
        var sec = cartEls[j].closest('[id^="shopify-section-"]');
        if (sec) {
          var sid = sec.id.replace('shopify-section-', '');
          if (!seen[sid]) {
            seen[sid] = true;
            ids.push(sid);
          }
        }
      }

      cachedSectionIds = ids;
      return ids;
    }

    /* ── Cart refresh — körs i bakgrunden, blockerar inte UI ─────── */
    function refreshCart() {
      var ids = getCartSectionIds();
      if (!ids.length) return;

      // "/" istället för window.location.pathname → servern slipper
      // processa hela kollektionssidan. Mycket snabbare.
      fetch('/?sections=' + ids.join(','), {
        credentials: 'same-origin',
        headers: { 'Accept': 'application/json' }
      })
        .then(function (r) { return r.json(); })
        .then(function (secs) {
          // Invalidera cachen om sektionerna byts ut, så vi hittar dem
          // korrekt nästa gång (deras parent-element finns kvar men
          // inre innehåll kan ha ändrats).
          for (var name in secs) {
            var target = document.getElementById('shopify-section-' + name);
            if (target && secs[name]) {
              target.outerHTML = secs[name];
            }
          }
        })
        .catch(function () {});
    }

    /* ── Klick-handler ── */
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('.product-card__buy-btn[data-quick-add]');
      if (!btn) return;
      if (btn.classList.contains('product-card__buy-btn--disabled')) return;
      if (btn.classList.contains('is-loading') || btn.classList.contains('is-success')) return;

      e.preventDefault();

      var variantId = btn.getAttribute('data-variant-id');
      if (!variantId) return;

      btn.classList.add('is-loading');

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({
          items: [{ id: Number(variantId), quantity: 1 }]
        })
      })
        .then(function (r) {
          if (!r.ok) throw new Error(r.status);
          return r.json();
        })
        .then(function () {
          // Visa success DIREKT när add lyckats — vänta inte på refresh
          btn.classList.remove('is-loading');
          btn.classList.add('is-success');
          setTimeout(function () { btn.classList.remove('is-success'); }, SUCCESS_MS);

          // Refresh cart i bakgrunden — UI är redan klar
          refreshCart();
        })
        .catch(function (err) {
          btn.classList.remove('is-loading');
          console.warn('[product-card] quick add failed:', err);
          var label = btn.querySelector('.btn-label');
          if (label) {
            var original = label.textContent;
            label.textContent = 'Fel';
            setTimeout(function () { label.textContent = original; }, 1600);
          }
        });
    }, { passive: false });

    /* ── Förbered cachen så fort DOM är redo ─────────────────────────
       Om DOM redan är klar när scriptet körs så cachar vi direkt.
       Annars väntar vi på DOMContentLoaded. Detta gör att första
       klicket inte behöver vänta på att vi scannar DOM. */
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', getCartSectionIds, { once: true });
    } else {
      getCartSectionIds();
    }
  })();
</script>