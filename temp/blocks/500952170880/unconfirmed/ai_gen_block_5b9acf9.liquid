{% doc %}
  @prompt
    "Write a how-it-works section in Swedish for a youth sports fundraising website selling high-quality Finnish licorice. The section has the following exact structure:
    The section starts with a heading: 'Tre steg — sedan rullar det på' followed by one intro sentence that explains the overall process takes a few weeks from application to payout.
    Then three steps follow. Each step has: a numbered circle icon (1, 2, 3) in teal/green color on the left, a bold short title on the same line as the number, and a body text of 2–3 sentences directly below the title, slightly indented to align with the title (not with the number).
    Step 1 title should be about filling in the contact form. Body text: we respond quickly, go through the setup with them, and help them get started in the best way for their team.
    Step 2 title should mention both receiving the products AND getting a webshop set up — connect these two things in the title with an em dash. Body text: the licorice is shipped to their home address. A dedicated webshop is created for their specific team. Customers pay directly into the webshop — the team never handles cash or invoices.
    Step 3 title should mention receiving the earnings AND the no-risk return policy — connect these in the title with an em dash. Body text: when the campaign ends, their share is paid out directly. Any unsold bags are simply sent back to us at no cost to them.
    The background is dark (near-black). Text is white. The numbered icons are filled circles in a teal green color. Bold titles are white and slightly larger than the body text. Body text is slightly muted/off-white.
    Tone across all three steps: removing worries, not adding tasks. Each step should feel like a reassurance. Write for a skeptical parent or team manager who has never done this before and needs to feel safe before they fill in the form. No bullet points within steps — only flowing sentences. Write entirely in Swedish."
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-how-it-works-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    width: 100%;
    display: block;
  }

  .ai-how-it-works-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    width: 100%;
  }

  .ai-how-it-works-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
    line-height: 1.2;
  }

  .ai-how-it-works-intro-{{ ai_gen_id }} {
    color: {{ block.settings.intro_color }};
    font-size: {{ block.settings.intro_size }}px;
    margin: 0 0 {{ block.settings.intro_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
    line-height: 1.5;
  }

  .ai-how-it-works-steps-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.step_spacing }}px;
  }

  .ai-how-it-works-step-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.icon_text_gap }}px;
    align-items: flex-start;
  }

  .ai-how-it-works-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    background-color: {{ block.settings.icon_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.icon_number_color }};
    font-size: {{ block.settings.icon_number_size }}px;
    font-weight: 700;
  }

  .ai-how-it-works-content-{{ ai_gen_id }} {
    flex: 1;
    padding-top: {{ block.settings.content_top_offset }}px;
  }

  .ai-how-it-works-step-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    margin: 0 0 {{ block.settings.title_spacing }}px;
    line-height: 1.3;
  }

  .ai-how-it-works-step-body-{{ ai_gen_id }} {
    color: {{ block.settings.body_color }};
    font-size: {{ block.settings.body_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-how-it-works-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.6 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-how-it-works-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-how-it-works-intro-{{ ai_gen_id }} {
      font-size: {{ block.settings.intro_size | times: 0.9 }}px;
    }

    .ai-how-it-works-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-how-it-works-icon-number-{{ ai_gen_id }} {
      font-size: {{ block.settings.icon_number_size | times: 0.8 }}px;
    }

    .ai-how-it-works-step-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-how-it-works-step-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<how-it-works-{{ ai_gen_id }} class="ai-how-it-works-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-how-it-works-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-how-it-works-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.intro != blank %}
      <div class="ai-how-it-works-intro-{{ ai_gen_id }}">{{ block.settings.intro }}</div>
    {% endif %}

    <div class="ai-how-it-works-steps-{{ ai_gen_id }}">
      {% if block.settings.step_1_title != blank %}
        <div class="ai-how-it-works-step-{{ ai_gen_id }}">
          <div class="ai-how-it-works-icon-{{ ai_gen_id }}">
            <span class="ai-how-it-works-icon-number-{{ ai_gen_id }}">1</span>
          </div>
          <div class="ai-how-it-works-content-{{ ai_gen_id }}">
            <h3 class="ai-how-it-works-step-title-{{ ai_gen_id }}">{{ block.settings.step_1_title }}</h3>
            <div class="ai-how-it-works-step-body-{{ ai_gen_id }}">{{ block.settings.step_1_body }}</div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.step_2_title != blank %}
        <div class="ai-how-it-works-step-{{ ai_gen_id }}">
          <div class="ai-how-it-works-icon-{{ ai_gen_id }}">
            <span class="ai-how-it-works-icon-number-{{ ai_gen_id }}">2</span>
          </div>
          <div class="ai-how-it-works-content-{{ ai_gen_id }}">
            <h3 class="ai-how-it-works-step-title-{{ ai_gen_id }}">{{ block.settings.step_2_title }}</h3>
            <div class="ai-how-it-works-step-body-{{ ai_gen_id }}">{{ block.settings.step_2_body }}</div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.step_3_title != blank %}
        <div class="ai-how-it-works-step-{{ ai_gen_id }}">
          <div class="ai-how-it-works-icon-{{ ai_gen_id }}">
            <span class="ai-how-it-works-icon-number-{{ ai_gen_id }}">3</span>
          </div>
          <div class="ai-how-it-works-content-{{ ai_gen_id }}">
            <h3 class="ai-how-it-works-step-title-{{ ai_gen_id }}">{{ block.settings.step_3_title }}</h3>
            <div class="ai-how-it-works-step-body-{{ ai_gen_id }}">{{ block.settings.step_3_body }}</div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</how-it-works-{{ ai_gen_id }}>

<script>
  (function() {
    class HowItWorks{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('how-it-works-{{ ai_gen_id }}', HowItWorks{{ ai_gen_id }});
  })();
</script>

