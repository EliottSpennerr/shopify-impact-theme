{% doc %}
  @prompt
    Write a 3-step how-it-works section in Swedish for a youth sports fundraising website. The product being sold is high-quality Finnish licorice. Format: each step has a short bold title (max 6 words) and a body text of 3–4 sentences that explains both what happens AND why it's good for the team.
    Step 1 is about filling in a contact form. We respond quickly, go through the setup together, and find the best solution for their specific team size and situation. Make it feel like a conversation, not a transaction.
    Step 2 is about receiving the products at home and getting a dedicated webshop set up specifically for their team. Customers can pay directly into the webshop — the team never handles cash or invoices. Emphasize that they can start selling immediately with the product physically in hand.
    Step 3 is about receiving the earnings. When the campaign is done, the money is paid out directly to the team. Any unsold bags are simply sent back to us — no cost, no questions. End this step with a forward-looking sentence about what the team can now do with the money.
    Tone: warm, clear and reassuring. Each step should feel like removing a worry, not adding a task. Write for a parent or team manager who is skeptical about whether this will actually be simple. No bullet points within the steps — flowing sentences only. Write in Swedish.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-how-it-works-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-how-it-works-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-how-it-works-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-how-it-works-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px 0;
    font-weight: 700;
  }

  .ai-how-it-works-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-how-it-works-steps-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: {{ block.settings.step_gap }}px;
    margin-top: {{ block.settings.steps_top_margin }}px;
  }

  .ai-how-it-works-step-{{ ai_gen_id }} {
    background-color: {{ block.settings.step_background }};
    padding: {{ block.settings.step_padding }}px;
    border-radius: {{ block.settings.step_border_radius }}px;
    position: relative;
  }

  .ai-how-it-works-step-number-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.number_size }}px;
    height: {{ block.settings.number_size }}px;
    background-color: {{ block.settings.number_background }};
    color: {{ block.settings.number_color }};
    border-radius: 50%;
    font-size: {{ block.settings.number_font_size }}px;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .ai-how-it-works-step-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.step_title_size }}px;
    color: {{ block.settings.step_title_color }};
    font-weight: 700;
    margin: 0 0 16px 0;
    line-height: 1.3;
  }

  .ai-how-it-works-step-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.step_text_size }}px;
    color: {{ block.settings.step_text_color }};
    line-height: 1.7;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-how-it-works-steps-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-how-it-works-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-how-it-works-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }
  }
{% endstyle %}

<how-it-works-{{ ai_gen_id }} class="ai-how-it-works-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-how-it-works-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-how-it-works-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-how-it-works-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <div class="ai-how-it-works-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-how-it-works-steps-{{ ai_gen_id }}">
      {% if block.settings.step_1_title != blank %}
        <div class="ai-how-it-works-step-{{ ai_gen_id }}">
          <div class="ai-how-it-works-step-number-{{ ai_gen_id }}">1</div>
          <h3 class="ai-how-it-works-step-title-{{ ai_gen_id }}">{{ block.settings.step_1_title }}</h3>
          <div class="ai-how-it-works-step-text-{{ ai_gen_id }}">{{ block.settings.step_1_text }}</div>
        </div>
      {% endif %}

      {% if block.settings.step_2_title != blank %}
        <div class="ai-how-it-works-step-{{ ai_gen_id }}">
          <div class="ai-how-it-works-step-number-{{ ai_gen_id }}">2</div>
          <h3 class="ai-how-it-works-step-title-{{ ai_gen_id }}">{{ block.settings.step_2_title }}</h3>
          <div class="ai-how-it-works-step-text-{{ ai_gen_id }}">{{ block.settings.step_2_text }}</div>
        </div>
      {% endif %}

      {% if block.settings.step_3_title != blank %}
        <div class="ai-how-it-works-step-{{ ai_gen_id }}">
          <div class="ai-how-it-works-step-number-{{ ai_gen_id }}">3</div>
          <h3 class="ai-how-it-works-step-title-{{ ai_gen_id }}">{{ block.settings.step_3_title }}</h3>
          <div class="ai-how-it-works-step-text-{{ ai_gen_id }}">{{ block.settings.step_3_text }}</div>
        </div>
      {% endif %}
    </div>
  </div>
</how-it-works-{{ ai_gen_id }}>

<script>
(function() {
  class HowItWorks{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      this.steps = this.querySelectorAll('.ai-how-it-works-step-{{ ai_gen_id }}');
    }
  }

  customElements.define('how-it-works-{{ ai_gen_id }}', HowItWorks{{ ai_gen_id }});
})();
</script>

