    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "number_size",
      "label": "Number circle size",
      "min": 40,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "number_font_size",
      "label": "Number font size",
      "min": 16,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 24
