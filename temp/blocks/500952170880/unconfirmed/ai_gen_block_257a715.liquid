{% doc %}
  @prompt
    "Write a 3-step process section in Swedish explaining how a licorice fundraising campaign works for a youth sports team. Each step has a bold short title and 2–3 sentences of explanation. Step 1: Fill in the contact form — we get back to you quickly and help you get started. Step 2: Products are shipped to you and we set up a dedicated webshop for your team — customers pay online, no cash involved. Step 3: Once the campaign ends, your earnings are paid out directly — any unsold bags are returned to us at no cost. Tone: clear, reassuring, human. No corporate language."
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-process-steps-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-process-steps__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-process-steps__title-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.title_spacing }}px;
  }

  .ai-process-steps__subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subtitle_size }}px;
    margin: 0;
  }

  .ai-process-steps__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: {{ block.settings.step_spacing }}px;
    margin-top: {{ block.settings.steps_top_margin }}px;
  }

  .ai-process-step-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.step_inner_spacing }}px;
  }

  .ai-process-step__number-{{ ai_gen_id }} {
    width: {{ block.settings.number_size }}px;
    height: {{ block.settings.number_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.number_background }};
    color: {{ block.settings.number_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.number_font_size }}px;
    font-weight: 600;
    flex-shrink: 0;
  }

  .ai-process-step__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-process-step__title-{{ ai_gen_id }} {
    color: {{ block.settings.step_title_color }};
    font-size: {{ block.settings.step_title_size }}px;
    font-weight: 700;
    margin: 0;
  }

  .ai-process-step__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-process-steps__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<process-steps-{{ ai_gen_id }} class="ai-process-steps-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank or block.settings.subtitle != blank %}
    <div class="ai-process-steps__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-process-steps__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <div class="ai-process-steps__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-process-steps__container-{{ ai_gen_id }}">
    {% if block.settings.step_1_title != blank %}
      <div class="ai-process-step-{{ ai_gen_id }}">
        <div class="ai-process-step__number-{{ ai_gen_id }}">1</div>
        <div class="ai-process-step__content-{{ ai_gen_id }}">
          <h3 class="ai-process-step__title-{{ ai_gen_id }}">{{ block.settings.step_1_title }}</h3>
          {% if block.settings.step_1_description != blank %}
            <div class="ai-process-step__description-{{ ai_gen_id }}">{{ block.settings.step_1_description }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.step_2_title != blank %}
      <div class="ai-process-step-{{ ai_gen_id }}">
        <div class="ai-process-step__number-{{ ai_gen_id }}">2</div>
        <div class="ai-process-step__content-{{ ai_gen_id }}">
          <h3 class="ai-process-step__title-{{ ai_gen_id }}">{{ block.settings.step_2_title }}</h3>
          {% if block.settings.step_2_description != blank %}
            <div class="ai-process-step__description-{{ ai_gen_id }}">{{ block.settings.step_2_description }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.step_3_title != blank %}
      <div class="ai-process-step-{{ ai_gen_id }}">
        <div class="ai-process-step__number-{{ ai_gen_id }}">3</div>
        <div class="ai-process-step__content-{{ ai_gen_id }}">
          <h3 class="ai-process-step__title-{{ ai_gen_id }}">{{ block.settings.step_3_title }}</h3>
          {% if block.settings.step_3_description != blank %}
            <div class="ai-process-step__description-{{ ai_gen_id }}">{{ block.settings.step_3_description }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</process-steps-{{ ai_gen_id }}>

<script>
  (function() {
    class ProcessSteps{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('process-steps-{{ ai_gen_id }}', ProcessSteps{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Process steps",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Så fungerar det"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Header alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Step 1"
    },
    {
      "type": "inline_richtext",
      "id": "step_1_title",
      "label": "Title",
      "default": "Fyll i kontaktformuläret"
    },
    {
      "type": "richtext",
      "id": "step_1_description",
      "label": "Description",
      "default": "<p>Vi hör av oss snabbt och hjälper er komma igång. Inga krångliga processer – bara en enkel start för er kampanj.</p>"
    },
    {
      "type": "header",
      "content": "Step 2"
    },
    {
      "type": "inline_richtext",
      "id": "step_2_title",
      "label": "Title",
      "default": "Produkterna skickas till er och vi sätter upp en egen webshop"
    },
    {
      "type": "richtext",
      "id": "step_2_description",
      "label": "Description",
      "default": "<p>Kunderna betalar online direkt till er – inga kontanter behövs. Allt sköts smidigt och säkert via webben.</p>"
    },
    {
      "type": "header",
      "content": "Step 3"
    },
    {
      "type": "inline_richtext",
      "id": "step_3_title",
      "label": "Title",
      "default": "När kampanjen är slut betalas er vinst ut direkt"
    },
    {
      "type": "richtext",
      "id": "step_3_description",
      "label": "Description",
      "default": "<p>Osålda påsar skickar ni tillbaka till oss utan kostnad. Ni tar ingen risk – bara vinst.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Header bottom spacing",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "steps_top_margin",
      "label": "Steps top margin",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "step_spacing",
      "label": "Space between steps",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "step_inner_spacing",
      "label": "Space inside step",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Gap between title and text",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#00234a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#00234a"
    },
    {
      "type": "color",
      "id": "step_title_color",
      "label": "Step title",
      "default": "#00234a"
    },
    {
      "type": "color",
      "id": "number_background",
      "label": "Number background",
      "default": "#005dc6"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Number text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
