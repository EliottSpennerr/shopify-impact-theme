{% doc %}
  @prompt
    Create an interactive profitability calculator section for a Shopify page with the following specs:
    The entire section sits inside a dark rounded card with background color #1a1a1a and 16px border-radius. The card is centered with max-width 560px and generous internal padding (40px top/bottom, 32px sides).
    Title: 'Hur mycket vill ni tjäna?' where the word 'ni' is in italic and teal (#1D9E75). Title is white, 26px, font-weight 600.
    Below the title: a small muted subtitle in gray (#888): 'Dra i reglagen — se resultatet direkt.'
    Two slider rows, each with the slider label on the left in light gray (#ccc, 14px) and an editable number input field on the right (dark background #2a2a2a, white text, rounded 8px, border highlights teal on focus). Below each label+input row sits the full-width range slider.
    Slider 1 — 'Personer som säljer' — range 1 to 100, default 20. Slider 2 — 'Produkter var att sälja' — range 1 to 100, default 15.
    Slider track: 4px tall, background #3a3a3a, border-radius 2px. Slider thumb: 20px circle, fill #1D9E75, with a 3px dark border (#1a1a1a) to lift it off the track.
    A thin horizontal rule (#2e2e2e) separates the sliders from the result.
    Below the divider: 'Ger er:' label on the left in muted gray, and the live result on the right in large bold teal (#1D9E75), 36px, font-weight 700. Result updates in real time: sellers × bags × 17, formatted as Swedish number format (e.g. '11 900 kr').
    Below the result: fine print in dark gray (#555), 12px: 'Genomsnittssäljaren säljer 35 påsar.'
    The number inputs and sliders must be fully synced — dragging the slider updates the input, and typing in the input updates the slider. Values are clamped between 1 and 100.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-profit-calc-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 20px;
  }

  .ai-profit-calc__card-{{ ai_gen_id }} {
    background-color: #1a1a1a;
    border-radius: 16px;
    padding: 40px 32px;
    max-width: 560px;
    margin: 0 auto;
  }

  .ai-profit-calc__title-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 26px;
    font-weight: 600;
    margin: 0 0 8px 0;
    line-height: 1.3;
  }

  .ai-profit-calc__title-italic-{{ ai_gen_id }} {
    font-style: italic;
    color: #1D9E75;
  }

  .ai-profit-calc__subtitle-{{ ai_gen_id }} {
    color: #888888;
    font-size: 14px;
    margin: 0 0 32px 0;
  }

  .ai-profit-calc__slider-row-{{ ai_gen_id }} {
    margin-bottom: 28px;
  }

  .ai-profit-calc__slider-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .ai-profit-calc__label-{{ ai_gen_id }} {
    color: #cccccc;
    font-size: 14px;
  }

  .ai-profit-calc__input-{{ ai_gen_id }} {
    background-color: #2a2a2a;
    color: #ffffff;
    border: 2px solid #2a2a2a;
    border-radius: 8px;
    padding: 6px 12px;
    width: 70px;
    text-align: center;
    font-size: 14px;
    transition: border-color 0.2s ease;
  }

  .ai-profit-calc__input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: #1D9E75;
  }

  .ai-profit-calc__slider-{{ ai_gen_id }} {
    width: 100%;
    height: 4px;
    background: #3a3a3a;
    border-radius: 2px;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
  }

  .ai-profit-calc__slider-{{ ai_gen_id }}::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #1D9E75;
    border: 3px solid #1a1a1a;
    cursor: pointer;
  }

  .ai-profit-calc__slider-{{ ai_gen_id }}::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #1D9E75;
    border: 3px solid #1a1a1a;
    cursor: pointer;
  }

  .ai-profit-calc__divider-{{ ai_gen_id }} {
    border: none;
    border-top: 1px solid #2e2e2e;
    margin: 32px 0 24px 0;
  }

  .ai-profit-calc__result-row-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .ai-profit-calc__result-label-{{ ai_gen_id }} {
    color: #888888;
    font-size: 14px;
  }

  .ai-profit-calc__result-value-{{ ai_gen_id }} {
    color: #1D9E75;
    font-size: 36px;
    font-weight: 700;
    line-height: 1;
  }

  .ai-profit-calc__footnote-{{ ai_gen_id }} {
    color: #555555;
    font-size: 12px;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-profit-calc__card-{{ ai_gen_id }} {
      padding: 32px 24px;
    }

    .ai-profit-calc__title-{{ ai_gen_id }} {
      font-size: 22px;
    }

    .ai-profit-calc__result-value-{{ ai_gen_id }} {
      font-size: 28px;
    }
  }
{% endstyle %}

<profit-calculator-{{ ai_gen_id }} class="ai-profit-calc-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-profit-calc__card-{{ ai_gen_id }}">
    <h2 class="ai-profit-calc__title-{{ ai_gen_id }}">
      Hur mycket vill <span class="ai-profit-calc__title-italic-{{ ai_gen_id }}">ni</span> tjäna?
    </h2>
    <p class="ai-profit-calc__subtitle-{{ ai_gen_id }}">
      Dra i reglagen — se resultatet direkt.
    </p>

    <div class="ai-profit-calc__slider-row-{{ ai_gen_id }}">
      <div class="ai-profit-calc__slider-header-{{ ai_gen_id }}">
        <label class="ai-profit-calc__label-{{ ai_gen_id }}" for="sellers-input-{{ ai_gen_id }}">
          Personer som säljer
        </label>
        <input
          type="number"
          id="sellers-input-{{ ai_gen_id }}"
          class="ai-profit-calc__input-{{ ai_gen_id }}"
          min="1"
          max="100"
          value="20"
          data-input="sellers"
        >
      </div>
      <input
        type="range"
        id="sellers-slider-{{ ai_gen_id }}"
        class="ai-profit-calc__slider-{{ ai_gen_id }}"
        min="1"
        max="100"
        value="20"
        data-slider="sellers"
      >
    </div>

    <div class="ai-profit-calc__slider-row-{{ ai_gen_id }}">
      <div class="ai-profit-calc__slider-header-{{ ai_gen_id }}">
        <label class="ai-profit-calc__label-{{ ai_gen_id }}" for="products-input-{{ ai_gen_id }}">
          Produkter var att sälja
        </label>
        <input
          type="number"
          id="products-input-{{ ai_gen_id }}"
          class="ai-profit-calc__input-{{ ai_gen_id }}"
          min="1"
          max="100"
          value="15"
          data-input="products"
        >
      </div>
      <input
        type="range"
        id="products-slider-{{ ai_gen_id }}"
        class="ai-profit-calc__slider-{{ ai_gen_id }}"
        min="1"
        max="100"
        value="15"
        data-slider="products"
      >
    </div>

    <hr class="ai-profit-calc__divider-{{ ai_gen_id }}">

    <div class="ai-profit-calc__result-row-{{ ai_gen_id }}">
      <span class="ai-profit-calc__result-label-{{ ai_gen_id }}">Ger er:</span>
      <span class="ai-profit-calc__result-value-{{ ai_gen_id }}" id="result-{{ ai_gen_id }}">10 200 kr</span>
    </div>

    <p class="ai-profit-calc__footnote-{{ ai_gen_id }}">
      Genomsnittssäljaren säljer 35 påsar.
    </p>
  </div>
</profit-calculator-{{ ai_gen_id }}>

<script>
  (function() {
    class ProfitCalculator{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.sellersInput = this.querySelector('[data-input="sellers"]');
        this.sellersSlider = this.querySelector('[data-slider="sellers"]');
        this.productsInput = this.querySelector('[data-input="products"]');
        this.productsSlider = this.querySelector('[data-slider="products"]');
        this.resultDisplay = this.querySelector('#result-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.sellersSlider.addEventListener('input', () => {
          this.sellersInput.value = this.sellersSlider.value;
          this.updateResult();
        });

        this.sellersInput.addEventListener('input', () => {
          let value = parseInt(this.sellersInput.value) || 1;
          value = Math.max(1, Math.min(100, value));
          this.sellersInput.value = value;
          this.sellersSlider.value = value;
          this.updateResult();
        });

        this.productsSlider.addEventListener('input', () => {
          this.productsInput.value = this.productsSlider.value;
          this.updateResult();
        });

        this.productsInput.addEventListener('input', () => {
          let value = parseInt(this.productsInput.value) || 1;
          value = Math.max(1, Math.min(100, value));
          this.productsInput.value = value;
          this.productsSlider.value = value;
          this.updateResult();
        });

        this.updateResult();
      }

      updateResult() {
        const sellers = parseInt(this.sellersInput.value) || 1;
        const products = parseInt(this.productsInput.value) || 1;
        const result = sellers * products * 17;
        
        this.resultDisplay.textContent = this.formatSwedish(result) + ' kr';
      }

      formatSwedish(number) {
        return number.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ' ');
      }
    }

    customElements.define('profit-calculator-{{ ai_gen_id }}', ProfitCalculator{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Profitability calculator",
  "settings": [
    {
      "type": "header",
      "content": "Calculator settings"
    },
    {
      "type": "paragraph",
      "content": "This calculator shows potential earnings based on number of sellers and products. Formula: sellers × products × 17 kr."
    }
  ],
  "presets": [
    {
      "name": "Profitability calculator"
    }
  ]
}
{% endschema %}
