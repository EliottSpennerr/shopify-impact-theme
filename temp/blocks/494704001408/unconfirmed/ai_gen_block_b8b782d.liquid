{% doc %}
  @prompt
    Create a modern hero header section with a rectangular layout and slightly rounded corners (not fully rounded). The section should have clear whitespace around it so it feels separated from the page edges.
    with changeable background color.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-header-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 20px;
  }

  .ai-hero-header__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.text_alignment }};
    justify-content: center;
    min-height: {{ block.settings.min_height }}px;
    position: relative;
    overflow: hidden;
  }

  .ai-hero-header__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-hero-header__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-hero-header__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 {{ block.settings.subheading_spacing }}px 0;
    line-height: 1.5;
  }

  .ai-hero-header__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
    line-height: 1.6;
  }

  .ai-hero-header__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-hero-header__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-hero-header__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  .ai-hero-header__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_background }};
    color: {{ block.settings.button_secondary_text_color }};
  }

  .ai-hero-header__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_hover_background }};
    color: {{ block.settings.button_secondary_hover_text_color }};
  }

  .ai-hero-header__background-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    opacity: {{ block.settings.image_opacity }};
  }

  .ai-hero-header__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-header__container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
      min-height: {{ block.settings.min_height | times: 0.7 }}px;
    }

    .ai-hero-header__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-hero-header__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-hero-header__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-hero-header__buttons-{{ ai_gen_id }} {
      flex-direction: column;
      width: 100%;
    }

    .ai-hero-header__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<hero-header-{{ ai_gen_id }} class="ai-hero-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-header__container-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-hero-header__background-image-{{ ai_gen_id }}"
      >
    {% endif %}

    {% if block.settings.show_overlay %}
      <div class="ai-hero-header__overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-hero-header__content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h1 class="ai-hero-header__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <h2 class="ai-hero-header__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-hero-header__text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}

      {% if block.settings.button_text != blank or block.settings.button_secondary_text != blank %}
        <div class="ai-hero-header__buttons-{{ ai_gen_id }}">
          {% if block.settings.button_text != blank %}
            <a
              href="{{ block.settings.button_link }}"
              class="ai-hero-header__button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          {% endif %}

          {% if block.settings.button_secondary_text != blank %}
            <a
              href="{{ block.settings.button_secondary_link }}"
              class="ai-hero-header__button-{{ ai_gen_id }} ai-hero-header__button--secondary-{{ ai_gen_id }}"
            >
              {{ block.settings.button_secondary_text }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</hero-header-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Hero header",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
