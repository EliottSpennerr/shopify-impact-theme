    { "type": "text", "id": "heading", "label": "Rubrik", "default": "Återförsäljarportal" },
    { "type": "textarea", "id": "subheading", "label": "Underrubrik", "default": "Beställ lådor till grossistpris direkt från oss. Logga in eller registrera ditt företag." },
    { "type": "collection", "id": "collection", "label": "Grossistkollektion (välj Wholesale)" },
    { "type": "number", "id": "min_order", "label": "Minimum order (kr)", "default": 2000 },
    { "type": "number", "id": "free_shipping", "label": "Fri frakt från (kr)", "default": 7000 },
    { "type": "text", "id": "b2b_tag", "label": "Kundtagg som ger åtkomst", "default": "b2b-pending", "info": "Måste matcha taggen Helium sätter vid registrering. Ta bort taggen på en kund för att stänga av åtkomsten." },
    { "type": "text", "id": "helium_form_id", "label": "Helium form-ID", "default": "zytR3V" },
    { "type": "text", "id": "contact_email", "label": "Kontakt-e-post", "info": "Visas vid fel och nekad åtkomst. Lämnas tom används butikens e-post." },
    { "type": "range", "id": "orders_count", "label": "Antal ordrar i historiken", "min": 5, "max": 50, "step": 5, "default": 10 }
  ],
  "presets": [{ "name": "Wholesale-portal" }]
}
{% endschema %}
