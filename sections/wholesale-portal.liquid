{% comment %}
  ============================================================
  WHOLESALE-PORTAL — Finsk Lakrits i Sverige AB
  ============================================================
  En sektion, tre lägen på samma sida (/pages/wholesale):

  1. UTLOGGAD  -> Logga in (Shopifys nya kundkonton) eller
                  registrera dig (eget UI -> Helium Customer
                  Fields JS-API, form zytR3V).
  2. INLOGGAD utan B2B-tagg -> felmeddelande + kontakt.
  3. INLOGGAD med B2B-tagg  -> portalen: progressbar för
                  minimum order + fri frakt, produktgrid från
                  Wholesale-kollektionen, flik med senaste
                  ordrar + "Beställ igen".

  KRAV INNAN DET FUNGERAR:
  - Heliums "lightweight API" (developer tools / app embed)
    måste vara aktiverad så att window.CF finns på sidan.
    Se developers.customerfields.com/installation.
  - Taggen sätts av er Helium-regel ("add tag: b2b-pending")
    vid submit med formId. Gate-taggen i inställningarna
    måste matcha den taggen.
  ============================================================
{% endcomment %}

{%- liquid
  assign ws_collection = section.settings.collection | default: collections['wholesale']
  assign gate_tag = section.settings.b2b_tag | strip
  assign min_order = section.settings.min_order | times: 100
  assign free_shipping = section.settings.free_shipping | times: 100
  assign contact_email = section.settings.contact_email | default: shop.email
  assign has_access = false
  if customer and customer.tags contains gate_tag
    assign has_access = true
  endif
-%}

<div class="wsp" id="wsp-root"
     data-min-order="{{ min_order }}"
     data-free-shipping="{{ free_shipping }}">

{%- if customer == blank -%}
  {%- comment -%} ================= LÄGE 1: UTLOGGAD ================= {%- endcomment -%}
  <div class="wsp-hero">
    <h1 class="wsp-h1">{{ section.settings.heading | default: 'Återförsäljarportal' }}</h1>
    <p class="wsp-sub">{{ section.settings.subheading | default: 'Beställ lådor till grossistpris direkt från oss. Logga in eller registrera ditt företag.' }}</p>
  </div>

  <div class="wsp-auth-grid">

    <div class="wsp-card">
      <h2 class="wsp-h2">Har du redan konto?</h2>
      <p>Logga in med din e-post — du får en engångskod skickad till dig. Är ditt konto godkänt som återförsäljare öppnas portalen direkt.</p>
      <a class="wsp-btn wsp-btn--primary" href="{{ routes.account_login_url }}?return_url=%2Fpages%2F{{ page.handle | default: 'wholesale' }}">Logga in</a>
    </div>

    <div class="wsp-card">
      <h2 class="wsp-h2">Ny återförsäljare</h2>
      <p>Fyll i företagsuppgifterna så skapas ditt konto direkt — utan väntetid.</p>

      <form id="wsp-register" novalidate>
        <div class="wsp-form-row">
          <div class="wsp-field">
            <label for="wsp-fname">Förnamn *</label>
            <input type="text" id="wsp-fname" required autocomplete="given-name">
          </div>
          <div class="wsp-field">
            <label for="wsp-lname">Efternamn *</label>
            <input type="text" id="wsp-lname" required autocomplete="family-name">
          </div>
        </div>

        <div class="wsp-field">
          <label for="wsp-email">E-post *</label>
          <input type="email" id="wsp-email" required autocomplete="email">
        </div>

        <div class="wsp-field">
          <label for="wsp-phone">Telefon</label>
          <input type="tel" id="wsp-phone" autocomplete="tel">
        </div>

        <div class="wsp-field">
          <label for="wsp-company">Företagsnamn *</label>
          <input type="text" id="wsp-company" required autocomplete="organization">
        </div>

        <div class="wsp-form-row">
          <div class="wsp-field">
            <label for="wsp-orgnr">Organisationsnummer *</label>
            <input type="text" id="wsp-orgnr" required inputmode="numeric" placeholder="5566778899">
          </div>
          <div class="wsp-field">
            <label for="wsp-momsnr">Momsregistreringsnummer *</label>
            <input type="text" id="wsp-momsnr" required placeholder="SE556677889901">
          </div>
        </div>

        <div class="wsp-field">
          <label for="wsp-address1">Leveransadress *</label>
          <input type="text" id="wsp-address1" required autocomplete="street-address">
        </div>

        <div class="wsp-form-row">
          <div class="wsp-field">
            <label for="wsp-zip">Postnummer *</label>
            <input type="text" id="wsp-zip" required autocomplete="postal-code">
          </div>
          <div class="wsp-field">
            <label for="wsp-city">Ort *</label>
            <input type="text" id="wsp-city" required autocomplete="address-level2">
          </div>
        </div>

        <button type="submit" class="wsp-btn wsp-btn--primary wsp-btn--full" id="wsp-register-btn">Skapa återförsäljarkonto</button>
        <p class="wsp-msg" id="wsp-register-msg" role="status" aria-live="polite"></p>
      </form>
    </div>
  </div>

{%- elsif has_access == false -%}
  {%- comment -%} ============ LÄGE 2: INLOGGAD UTAN TAGG ============ {%- endcomment -%}
  <div class="wsp-hero">
    <h1 class="wsp-h1">{{ section.settings.heading | default: 'Återförsäljarportal' }}</h1>
  </div>
  <div class="wsp-card wsp-card--center wsp-card--narrow">
    <div class="wsp-lock">&#128274;</div>
    <h2 class="wsp-h2">Ditt konto har inte återförsäljaråtkomst</h2>
    <p>Du är inloggad som {{ customer.email }}, men kontot är inte registrerat som återförsäljare. Har du nyligen ansökt kan det dröja en kort stund — prova att ladda om sidan. Annars hör av dig så hjälper vi dig direkt.</p>
    <a class="wsp-btn wsp-btn--primary" href="mailto:{{ contact_email }}">Kontakta oss</a>
    <a class="wsp-btn wsp-btn--ghost" href="{{ routes.account_logout_url }}">Logga ut</a>
  </div>

{%- else -%}
  {%- comment -%} ============ LÄGE 3: PORTALEN (INLOGGAD + TAGG) ============ {%- endcomment -%}

  <div class="wsp-portal-head">
    <div>
      <h1 class="wsp-h1">{{ section.settings.heading | default: 'Återförsäljarportal' }}</h1>
      <p class="wsp-sub">Inloggad som <strong>{{ customer.default_address.company | default: customer.email }}</strong> · <a href="{{ routes.account_url }}">Mitt konto</a> · <a href="{{ routes.account_logout_url }}">Logga ut</a></p>
    </div>
  </div>

  {%- comment -%} Sticky bar: minimum order + fri frakt {%- endcomment -%}
  <div class="wsp-bar" id="wsp-bar">
    <div class="wsp-bar-track">
      <div class="wsp-bar-fill" id="wsp-bar-fill"></div>
      <div class="wsp-bar-marker" id="wsp-marker-min" title="Minimum order"></div>
    </div>
    <div class="wsp-bar-info">
      <span id="wsp-bar-text">Laddar varukorg…</span>
      <span class="wsp-bar-total">Varukorg: <strong id="wsp-cart-total">0 kr</strong></span>
      <a href="/checkout" class="wsp-btn wsp-btn--checkout wsp-btn--disabled" id="wsp-checkout-btn" aria-disabled="true">Till kassan</a>
    </div>
  </div>

  {%- comment -%} Flikar {%- endcomment -%}
  <div class="wsp-tabs" role="tablist">
    <button class="wsp-tab wsp-tab--active" data-tab="products" role="tab" aria-selected="true">Produkter</button>
    <button class="wsp-tab" data-tab="orders" role="tab" aria-selected="false">Mina ordrar</button>
  </div>

  {%- comment -%} ---- FLIK: PRODUKTER ---- {%- endcomment -%}
  <div class="wsp-panel" id="wsp-panel-products">
    {%- if ws_collection == blank or ws_collection.products_count == 0 -%}
      <p class="wsp-empty">Ingen grossistkollektion vald. Välj kollektionen "Wholesale" i sektionens inställningar.</p>
    {%- else -%}
      <div class="wsp-grid">
        {%- paginate ws_collection.products by 48 -%}
        {%- for product in ws_collection.products -%}
          {%- assign v = product.selected_or_first_available_variant -%}
          <div class="wsp-product">
            <a href="{{ product.url }}" class="wsp-product-img" tabindex="-1">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 360 }}"
                     alt="{{ product.featured_image.alt | default: product.title | escape }}"
                     loading="lazy" width="360" height="{{ 360 | divided_by: product.featured_image.aspect_ratio | round }}">
              {%- else -%}
                <div class="wsp-noimg">Bild saknas</div>
              {%- endif -%}
            </a>
            <div class="wsp-product-body">
              <h3 class="wsp-product-title">{{ product.title }}</h3>
              <p class="wsp-product-price">{{ v.price | money }}{% if v.unit_price %} <span class="wsp-unit">({{ v.unit_price | money }}/{{ v.unit_price_measurement.reference_unit }})</span>{% endif %}</p>
              {%- if v.available -%}
                <div class="wsp-qty-row">
                  <div class="wsp-qty">
                    <button type="button" class="wsp-qty-btn" data-step="-1" aria-label="Minska antal">&minus;</button>
                    <input type="number" class="wsp-qty-input" value="1" min="1" max="999" inputmode="numeric" aria-label="Antal lådor">
                    <button type="button" class="wsp-qty-btn" data-step="1" aria-label="Öka antal">+</button>
                  </div>
                  <button type="button" class="wsp-btn wsp-btn--primary wsp-add" data-variant-id="{{ v.id }}">Lägg i varukorg</button>
                </div>
              {%- else -%}
                <p class="wsp-soldout">Tillfälligt slut</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
        {%- endpaginate -%}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ---- FLIK: MINA ORDRAR ---- {%- endcomment -%}
  <div class="wsp-panel wsp-panel--hidden" id="wsp-panel-orders">
    {%- if customer.orders_count == 0 -%}
      <p class="wsp-empty">Du har inte lagt några ordrar ännu. Din första order dyker upp här.</p>
    {%- else -%}
      <div class="wsp-orders">
        {%- for order in customer.orders limit: section.settings.orders_count -%}
          {%- capture reorder_items -%}
            {%- assign first = true -%}
            [{%- for item in order.line_items -%}{%- if item.variant_id -%}{%- unless first -%},{%- endunless -%}{"id":{{ item.variant_id }},"quantity":{{ item.quantity }}}{%- assign first = false -%}{%- endif -%}{%- endfor -%}]
          {%- endcapture -%}
          <div class="wsp-order">
            <div class="wsp-order-main">
              <span class="wsp-order-name">{{ order.name }}</span>
              <span class="wsp-order-date">{{ order.created_at | date: '%-d %b %Y' }}</span>
              <span class="wsp-order-status">{{ order.financial_status_label }} · {{ order.fulfillment_status_label }}</span>
              <span class="wsp-order-total">{{ order.total_price | money }}</span>
            </div>
            <details class="wsp-order-details">
              <summary>{{ order.line_items.size }} artiklar</summary>
              <ul>
                {%- for item in order.line_items -%}
                  <li>{{ item.quantity }} &times; {{ item.title }}</li>
                {%- endfor -%}
              </ul>
            </details>
            <div class="wsp-order-actions">
              <a href="{{ order.customer_url }}" class="wsp-btn wsp-btn--ghost wsp-btn--sm">Visa order</a>
              <button type="button" class="wsp-btn wsp-btn--primary wsp-btn--sm wsp-reorder" data-items='{{ reorder_items | strip }}'>Beställ igen</button>
            </div>
          </div>
        {%- endfor -%}
      </div>
      <p class="wsp-note">Fler ordrar hittar du under <a href="{{ routes.account_url }}">Mitt konto</a>.</p>
    {%- endif -%}
  </div>

  {%- comment -%} Toast {%- endcomment -%}
  <div class="wsp-toast" id="wsp-toast" role="status" aria-live="polite"></div>

{%- endif -%}
</div>

{%- comment -%} ===================== CSS ===================== {%- endcomment -%}
<style>
  .wsp { max-width: 1200px; margin: 0 auto; padding: 24px 20px 64px; color: #00234a; }
  .wsp-h1 { font-family: 'Barlow', sans-serif; font-size: clamp(28px, 4vw, 42px); font-weight: 700; margin: 0 0 8px; }
  .wsp-h2 { font-family: 'Barlow', sans-serif; font-size: 22px; font-weight: 700; margin: 0 0 10px; }
  .wsp-sub { font-size: 16px; opacity: .85; margin: 0; }
  .wsp-sub a { color: #005dc6; }
  .wsp-hero { text-align: center; padding: 24px 0 32px; }

  .wsp-auth-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 24px; align-items: start; }
  @media (max-width: 820px) { .wsp-auth-grid { grid-template-columns: 1fr; } }

  .wsp-card { background: #fff; border: 1px solid #e3e6ea; border-radius: 16px; padding: 28px; }
  .wsp-card--center { text-align: center; }
  .wsp-card--narrow { max-width: 560px; margin: 0 auto; }
  .wsp-lock { font-size: 40px; margin-bottom: 8px; }

  .wsp-field { margin-bottom: 14px; display: flex; flex-direction: column; }
  .wsp-field label { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
  .wsp-field input { border: 1px solid #c9ced6; border-radius: 10px; padding: 10px 12px; font-size: 15px; }
  .wsp-field input:focus { outline: 2px solid #005dc6; border-color: #005dc6; }
  .wsp-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (max-width: 520px) { .wsp-form-row { grid-template-columns: 1fr; } }

  .wsp-btn { display: inline-block; border: none; cursor: pointer; text-decoration: none; text-align: center;
             font-family: 'Barlow', sans-serif; font-weight: 700; font-size: 15px;
             padding: 12px 26px; border-radius: 60px; transition: opacity .15s ease; }
  .wsp-btn:hover { opacity: .88; }
  .wsp-btn--primary { background: #005dc6; color: #fff; }
  .wsp-btn--ghost { background: transparent; color: #00234a; border: 1px solid #c9ced6; margin-left: 8px; }
  .wsp-btn--full { width: 100%; margin-top: 6px; }
  .wsp-btn--sm { padding: 8px 18px; font-size: 14px; }
  .wsp-btn--checkout { background: #f0c417; color: #00234a; white-space: nowrap; }
  .wsp-btn--disabled { opacity: .45; pointer-events: none; }

  .wsp-msg { font-size: 14px; margin: 10px 0 0; min-height: 1.2em; }
  .wsp-msg--error { color: #b3261e; }
  .wsp-msg--ok { color: #1c7c3c; }

  .wsp-portal-head { display: flex; justify-content: space-between; align-items: end; gap: 16px; padding: 8px 0 18px; flex-wrap: wrap; }

  .wsp-bar { position: sticky; top: 0; z-index: 40; background: #00234a; color: #fff;
             border-radius: 14px; padding: 14px 18px; margin-bottom: 22px; }
  .wsp-bar-track { position: relative; height: 10px; background: rgba(255,255,255,.18); border-radius: 6px; overflow: visible; }
  .wsp-bar-fill { height: 100%; width: 0%; background: #f0c417; border-radius: 6px; transition: width .35s ease; }
  .wsp-bar-marker { position: absolute; top: -4px; width: 2px; height: 18px; background: #fff; opacity: .7; }
  .wsp-bar-info { display: flex; align-items: center; justify-content: space-between; gap: 14px; margin-top: 10px; flex-wrap: wrap; font-size: 14px; }
  .wsp-bar-total { opacity: .9; }

  .wsp-tabs { display: flex; gap: 8px; margin-bottom: 18px; border-bottom: 2px solid #e3e6ea; }
  .wsp-tab { background: none; border: none; cursor: pointer; font-family: 'Barlow', sans-serif; font-weight: 700;
             font-size: 16px; padding: 10px 16px; color: #00234a; opacity: .55; border-bottom: 3px solid transparent; margin-bottom: -2px; }
  .wsp-tab--active { opacity: 1; border-bottom-color: #005dc6; }

  .wsp-panel--hidden { display: none; }
  .wsp-empty { padding: 32px 0; text-align: center; opacity: .8; }
  .wsp-note { font-size: 13px; opacity: .75; margin-top: 14px; }
  .wsp-note a { color: #005dc6; }

  .wsp-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 18px; }
  .wsp-product { background: #fff; border: 1px solid #e3e6ea; border-radius: 14px; overflow: hidden; display: flex; flex-direction: column; }
  .wsp-product-img { display: block; aspect-ratio: 1/1; background: #f0f0f0; }
  .wsp-product-img img { width: 100%; height: 100%; object-fit: contain; }
  .wsp-noimg { display: flex; align-items: center; justify-content: center; height: 100%; opacity: .5; font-size: 13px; }
  .wsp-product-body { padding: 14px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .wsp-product-title { font-size: 15px; font-weight: 600; margin: 0; line-height: 1.35; }
  .wsp-product-price { font-family: 'Barlow', sans-serif; font-weight: 700; font-size: 17px; margin: 0; }
  .wsp-unit { font-size: 12px; font-weight: 400; opacity: .7; }
  .wsp-soldout { color: #b3261e; font-size: 14px; margin: auto 0 0; }
  .wsp-qty-row { display: flex; gap: 8px; margin-top: auto; align-items: stretch; }
  .wsp-qty { display: flex; border: 1px solid #c9ced6; border-radius: 60px; overflow: hidden; }
  .wsp-qty-btn { width: 32px; border: none; background: #f0f0f0; cursor: pointer; font-size: 16px; }
  .wsp-qty-input { width: 42px; border: none; text-align: center; font-size: 14px; -moz-appearance: textfield; }
  .wsp-qty-input::-webkit-outer-spin-button, .wsp-qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }
  .wsp-add { flex: 1; padding: 10px 8px; font-size: 14px; }

  .wsp-orders { display: flex; flex-direction: column; gap: 12px; }
  .wsp-order { background: #fff; border: 1px solid #e3e6ea; border-radius: 14px; padding: 16px 18px; }
  .wsp-order-main { display: grid; grid-template-columns: auto 1fr auto auto; gap: 14px; align-items: center; font-size: 15px; }
  @media (max-width: 680px) { .wsp-order-main { grid-template-columns: 1fr 1fr; } }
  .wsp-order-name { font-weight: 700; font-family: 'Barlow', sans-serif; }
  .wsp-order-date, .wsp-order-status { opacity: .75; font-size: 14px; }
  .wsp-order-total { font-weight: 700; }
  .wsp-order-details { margin-top: 8px; font-size: 14px; }
  .wsp-order-details summary { cursor: pointer; color: #005dc6; }
  .wsp-order-details ul { margin: 8px 0 0; padding-left: 18px; }
  .wsp-order-actions { margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap; }

  .wsp-toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(20px);
               background: #00234a; color: #fff; padding: 12px 22px; border-radius: 60px; font-size: 14px;
               opacity: 0; pointer-events: none; transition: all .25s ease; z-index: 80; }
  .wsp-toast--show { opacity: 1; transform: translateX(-50%) translateY(0); }
</style>

{%- comment -%} ===================== JS ===================== {%- endcomment -%}
<script>
(function () {
  var root = document.getElementById('wsp-root');
  if (!root) return;

  /* ---------- Hjälpare ---------- */
  function sek(cents) {
    return new Intl.NumberFormat('sv-SE', { maximumFractionDigits: 0 }).format(cents / 100) + ' kr';
  }
  function toast(msg) {
    var t = document.getElementById('wsp-toast');
    if (!t) return;
    t.textContent = msg;
    t.classList.add('wsp-toast--show');
    clearTimeout(t._h);
    t._h = setTimeout(function () { t.classList.remove('wsp-toast--show'); }, 3200);
  }

  /* ================================================================
     REGISTRERING (läge 1) — eget UI ovanpå Helium Customer Fields
     ================================================================ */
  var regForm = document.getElementById('wsp-register');
  if (regForm) {
    var HELIUM_FORM_ID = {{ section.settings.helium_form_id | default: 'zytR3V' | json }};
    regForm.addEventListener('submit', function (e) {
      e.preventDefault();
      var msg = document.getElementById('wsp-register-msg');
      var btn = document.getElementById('wsp-register-btn');
      msg.className = 'wsp-msg';
      msg.textContent = '';

      if (!regForm.checkValidity()) { regForm.reportValidity(); return; }

      if (!window.CF || !window.CF.customerReady) {
        msg.classList.add('wsp-msg--error');
        msg.textContent = 'Registreringen kunde inte laddas. Ladda om sidan eller mejla {{ contact_email }} så hjälper vi dig.';
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Skapar konto…';

      window.CF.customerReady(function () {
        try {
          /* OBS: nycklarna här måste matcha Heliums datakolumner.
             company -> defaultAddress.company, org_nr/momsnr -> custom-metafält.
             Adressnycklarna är Heliums standardkolumner — verifiera vid första test. */
          CF.customer.set({
            email:      document.getElementById('wsp-email').value.trim(),
            first_name: document.getElementById('wsp-fname').value.trim(),
            last_name:  document.getElementById('wsp-lname').value.trim(),
            phone:      document.getElementById('wsp-phone').value.trim(),
            company:    document.getElementById('wsp-company').value.trim(),
            org_nr:     document.getElementById('wsp-orgnr').value.replace(/[^0-9]/g, ''),
            momsnr:     document.getElementById('wsp-momsnr').value.replace(/\s+/g, '').toUpperCase(),
            address1:   document.getElementById('wsp-address1').value.trim(),
            zip:        document.getElementById('wsp-zip').value.trim(),
            city:       document.getElementById('wsp-city').value.trim(),
            country:    'Sweden'
          });

          /* Taggen sätts av er Helium-regel vid submit med formId.
             Behöver den sättas explicit i stället, avkommentera raden
             nedan och whitelista taggen i Helium (Advanced settings):
          CF.customer.addTag('b2b-pending');
          */

          CF.customer.save({ formId: HELIUM_FORM_ID, login: true })
            .then(function () {
              msg.classList.add('wsp-msg--ok');
              msg.textContent = 'Klart! Ditt konto är skapat — sidan laddas om…';
              setTimeout(function () { window.location.reload(); }, 1400);
            })
            .catch(function (err) {
              btn.disabled = false;
              btn.textContent = 'Skapa återförsäljarkonto';
              msg.classList.add('wsp-msg--error');
              var detail = (err && err.message) ? err.message : 'Kontrollera uppgifterna och försök igen.';
              msg.textContent = 'Det gick inte att skapa kontot: ' + detail;
            });
        } catch (err) {
          btn.disabled = false;
          btn.textContent = 'Skapa återförsäljarkonto';
          msg.classList.add('wsp-msg--error');
          msg.textContent = 'Ett tekniskt fel uppstod. Mejla {{ contact_email }} så hjälper vi dig.';
        }
      });
    });
  }

  /* ================================================================
     PORTALEN (läge 3) — bar, flikar, varukorg, beställ igen
     ================================================================ */
  var bar = document.getElementById('wsp-bar');
  if (!bar) return; /* inte i portal-läge -> klart */

  var MIN_ORDER = parseInt(root.dataset.minOrder, 10) || 0;       /* öre */
  var FREE_SHIP = parseInt(root.dataset.freeShipping, 10) || 0;   /* öre */

  /* ---------- Flikar ---------- */
  document.querySelectorAll('.wsp-tab').forEach(function (tab) {
    tab.addEventListener('click', function () {
      document.querySelectorAll('.wsp-tab').forEach(function (t) {
        t.classList.remove('wsp-tab--active'); t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('wsp-tab--active'); tab.setAttribute('aria-selected', 'true');
      document.getElementById('wsp-panel-products').classList.toggle('wsp-panel--hidden', tab.dataset.tab !== 'products');
      document.getElementById('wsp-panel-orders').classList.toggle('wsp-panel--hidden', tab.dataset.tab !== 'orders');
    });
  });

  /* ---------- Bar / varukorg ---------- */
  function renderBar(totalCents) {
    var fill = document.getElementById('wsp-bar-fill');
    var text = document.getElementById('wsp-bar-text');
    var totalEl = document.getElementById('wsp-cart-total');
    var checkout = document.getElementById('wsp-checkout-btn');
    var marker = document.getElementById('wsp-marker-min');

    var goal = Math.max(FREE_SHIP, MIN_ORDER) || 1;
    var pct = Math.min(100, (totalCents / goal) * 100);
    fill.style.width = pct + '%';
    if (marker) marker.style.left = Math.min(100, (MIN_ORDER / goal) * 100) + '%';
    totalEl.textContent = sek(totalCents);

    if (totalCents <= 0) {
      text.textContent = 'Din varukorg är tom. Minimum order: ' + sek(MIN_ORDER) + '.';
    } else if (totalCents < MIN_ORDER) {
      text.textContent = sek(MIN_ORDER - totalCents) + ' kvar till minimum order (' + sek(MIN_ORDER) + ').';
    } else if (FREE_SHIP > MIN_ORDER && totalCents < FREE_SHIP) {
      text.textContent = 'Minimum order uppnådd ✓ — ' + sek(FREE_SHIP - totalCents) + ' kvar till fri frakt.';
    } else {
      text.textContent = FREE_SHIP > 0 ? 'Fri frakt ✓ — du är klar att checka ut.' : 'Minimum order uppnådd ✓';
    }

    var ok = totalCents >= MIN_ORDER && totalCents > 0;
    checkout.classList.toggle('wsp-btn--disabled', !ok);
    checkout.setAttribute('aria-disabled', String(!ok));
  }

  function refreshCart() {
    return fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
      .then(function (r) { return r.json(); })
      .then(function (cart) { renderBar(cart.total_price || 0); return cart; })
      .catch(function () { renderBar(0); });
  }

  function addItems(items, btn, doneLabel) {
    if (btn) { btn.disabled = true; btn.dataset.orig = btn.textContent; btn.textContent = 'Lägger till…'; }
    return fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ items: items })
    })
    .then(function (r) {
      if (!r.ok) return r.json().then(function (e) { throw e; });
      return r.json();
    })
    .then(function () {
      toast(doneLabel || 'Tillagd i varukorgen ✓');
      return refreshCart();
    })
    .catch(function (err) {
      var d = (err && (err.description || err.message)) || 'Försök igen.';
      toast('Kunde inte lägga till: ' + d);
    })
    .finally(function () {
      if (btn) { btn.disabled = false; btn.textContent = btn.dataset.orig; }
    });
  }

  /* ---------- Antal +/- ---------- */
  root.addEventListener('click', function (e) {
    var step = e.target.closest('.wsp-qty-btn');
    if (step) {
      var input = step.parentElement.querySelector('.wsp-qty-input');
      var v = parseInt(input.value, 10) || 1;
      input.value = Math.max(1, v + parseInt(step.dataset.step, 10));
      return;
    }

    /* ---------- Lägg i varukorg ---------- */
    var add = e.target.closest('.wsp-add');
    if (add) {
      var qtyInput = add.closest('.wsp-qty-row').querySelector('.wsp-qty-input');
      var qty = Math.max(1, parseInt(qtyInput.value, 10) || 1);
      addItems([{ id: parseInt(add.dataset.variantId, 10), quantity: qty }], add);
      return;
    }

    /* ---------- Beställ igen ---------- */
    var re = e.target.closest('.wsp-reorder');
    if (re) {
      var items;
      try { items = JSON.parse(re.dataset.items); } catch (_) { items = []; }
      if (!items.length) { toast('Ordern innehåller inga produkter som finns kvar.'); return; }
      addItems(items, re, 'Ordern är tillagd i varukorgen ✓');
    }
  });

  refreshCart();
})();
</script>

