{%- comment -%}
  ============================================================
  Section: Återförsäljarportal (B2B login + registrering)
  Fil: sections/aterforsaljare-portal.liquid
  ------------------------------------------------------------
  Layout: bild till vänster, kort till höger (staplas på mobil).
  Flöde:
    - Inloggad kund  -> skickas direkt till grossistkatalogen.
    - Utloggad       -> Logga in (default). "Inte kund? Registrera
                        dig" fäller fram registreringsformuläret.
  Färger: default hämtade från ert Impact-tema (marinblå #00234a,
  blå knapp #005dc6, ljusgrå #f0f0f0). Allt går att ändra i editorn.

  KONTOSYSTEM:
    - Klassiska kundkonton (lösenord): låt "Använd Shopifys
      inloggningssida" vara AV -> login/registrering körs i kortet.
    - Nya kundkonton (inloggning via e-postkod): slå PÅ "Använd
      Shopifys inloggningssida" -> kortet visar knappar till
      Shopifys egna sidor istället (det inbäddade lösenords-
      formuläret fungerar inte med nya konton).

  Registrering taggar kontot (default "B2B-ansökan"). Toggle
  "Släpp in alla direkt" byter till direkt-taggen. OBS: taggen ger
  inte grossistpriser i sig - koppla den till Flow/app + B2B-katalog.
  ============================================================
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign uid = section.id
  assign catalog = s.catalog_url
  if catalog == blank
    assign catalog = routes.account_url
  endif
  assign apply_tag = s.application_tag
  assign success_msg = s.success_text
  if s.auto_approve
    assign apply_tag = s.approved_tag
    assign success_msg = s.success_text_direct
  endif
-%}

<style>
  #flb2b-{{ uid }} {
    --c-bg: {{ s.bg_color }};
    --c-card: {{ s.card_color }};
    --c-ink: {{ s.text_color }};
    --c-accent: {{ s.accent_color }};
    --c-btn-text: {{ s.button_text_color }};
    --c-media: {{ s.media_bg_color }};
    --c-line: color-mix(in srgb, {{ s.text_color }} 16%, transparent);
    --c-soft: color-mix(in srgb, {{ s.accent_color }} 8%, transparent);
    --r-card: {{ s.card_radius }}px;
    --r-input: {{ s.input_radius }}px;
    --r-btn: {{ s.button_radius }}px;
  }
  #flb2b-{{ uid }} { background: var(--c-bg); color: var(--c-ink); padding: {{ s.padding_top }}px 20px {{ s.padding_bottom }}px; }
  #flb2b-{{ uid }} * { box-sizing: border-box; }
  #flb2b-{{ uid }} .flb2b__wrap {
    max-width: 1120px; margin: 0 auto; display: grid;
    grid-template-columns: 1fr 1fr; gap: 24px; align-items: stretch;
  }

  /* Vänster: bild */
  #flb2b-{{ uid }} .flb2b__media {
    position: relative; border-radius: var(--r-card); overflow: hidden;
    background: var(--c-media); min-height: 460px; display: flex; align-items: flex-end;
  }
  #flb2b-{{ uid }} .flb2b__media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  #flb2b-{{ uid }} .flb2b__media-cap {
    position: relative; z-index: 1; padding: 32px;
    color: #fff; background: linear-gradient(to top, rgba(0,0,0,.55), rgba(0,0,0,0));
    width: 100%;
  }
  #flb2b-{{ uid }} .flb2b__media-eyebrow { font-size: 12px; letter-spacing: .22em; text-transform: uppercase; opacity: .85; margin: 0 0 10px; }
  #flb2b-{{ uid }} .flb2b__media-cap h2 { font-size: clamp(24px, 3vw, 34px); line-height: 1.1; margin: 0 0 8px; font-weight: 600; letter-spacing: -.01em; }
  #flb2b-{{ uid }} .flb2b__media-cap p { font-size: 15px; line-height: 1.5; margin: 0; opacity: .9; }

  /* Höger: kort */
  #flb2b-{{ uid }} .flb2b__card {
    background: var(--c-card); border-radius: var(--r-card); padding: 36px;
    box-shadow: 0 18px 40px color-mix(in srgb, var(--c-ink) 10%, transparent);
    display: flex; flex-direction: column;
  }
  #flb2b-{{ uid }} .flb2b__bar { height: 4px; border-radius: 4px; background: var(--c-line); margin-bottom: 28px; overflow: hidden; }
  #flb2b-{{ uid }} .flb2b__bar span { display: block; height: 100%; width: 50%; background: var(--c-accent); border-radius: 4px; }
  #flb2b-{{ uid }} .flb2b__step { font-size: 12px; letter-spacing: .18em; text-transform: uppercase; opacity: .55; margin: 0 0 12px; }
  #flb2b-{{ uid }} .flb2b__h { font-size: clamp(24px, 3vw, 32px); font-weight: 600; letter-spacing: -.02em; margin: 0 0 8px; }
  #flb2b-{{ uid }} .flb2b__sub { font-size: 15px; line-height: 1.55; opacity: .7; margin: 0 0 24px; }

  #flb2b-{{ uid }} .flb2b__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  #flb2b-{{ uid }} .flb2b__field { display: flex; flex-direction: column; gap: 6px; }
  #flb2b-{{ uid }} .flb2b__field--full { grid-column: 1 / -1; }
  #flb2b-{{ uid }} .flb2b__field label { font-size: 13px; font-weight: 600; }
  #flb2b-{{ uid }} .flb2b__field .req { color: var(--c-accent); }
  #flb2b-{{ uid }} .flb2b__field input,
  #flb2b-{{ uid }} .flb2b__field textarea {
    width: 100%; font: inherit; font-size: 15px; color: var(--c-ink); padding: 12px 14px;
    background: var(--c-bg); border: 1px solid var(--c-line); border-radius: var(--r-input);
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  #flb2b-{{ uid }} .flb2b__field input:focus,
  #flb2b-{{ uid }} .flb2b__field textarea:focus {
    outline: none; border-color: var(--c-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--c-accent) 20%, transparent);
  }
  #flb2b-{{ uid }} .flb2b__field textarea { resize: vertical; min-height: 80px; }
  #flb2b-{{ uid }} .flb2b__hint { font-size: 12px; opacity: .55; }

  /* Pills (verksamhetstyp) */
  #flb2b-{{ uid }} .flb2b__pills { display: flex; flex-wrap: wrap; gap: 10px; }
  #flb2b-{{ uid }} .flb2b__pill { position: relative; cursor: pointer; }
  #flb2b-{{ uid }} .flb2b__pill input { position: absolute; opacity: 0; width: 0; height: 0; }
  #flb2b-{{ uid }} .flb2b__pill span {
    display: inline-flex; align-items: center; gap: 8px; padding: 10px 18px;
    border: 1px solid var(--c-line); border-radius: var(--r-btn); font-size: 14px;
    transition: border-color .15s ease, background .15s ease;
  }
  #flb2b-{{ uid }} .flb2b__pill input:checked + span { border-color: var(--c-accent); background: var(--c-soft); font-weight: 600; }
  #flb2b-{{ uid }} .flb2b__pill input:focus-visible + span { box-shadow: 0 0 0 3px color-mix(in srgb, var(--c-accent) 20%, transparent); }

  #flb2b-{{ uid }} .flb2b__check { grid-column: 1 / -1; display: flex; gap: 10px; align-items: flex-start; font-size: 13px; opacity: .85; }
  #flb2b-{{ uid }} .flb2b__check input { width: 16px; height: 16px; margin-top: 1px; }

  #flb2b-{{ uid }} .flb2b__btn {
    display: inline-flex; align-items: center; justify-content: center; width: 100%;
    font: inherit; font-size: 15px; font-weight: 600; cursor: pointer; text-decoration: none;
    background: var(--c-accent); color: var(--c-btn-text); border: none;
    border-radius: var(--r-btn); padding: 15px 24px; margin-top: 6px;
    transition: opacity .15s ease, transform .05s ease;
  }
  #flb2b-{{ uid }} .flb2b__btn:hover { opacity: .9; }
  #flb2b-{{ uid }} .flb2b__btn:active { transform: translateY(1px); }
  #flb2b-{{ uid }} .flb2b__switch { font-size: 14px; opacity: .85; margin: 18px 0 0; text-align: center; }
  #flb2b-{{ uid }} .flb2b__link {
    font: inherit; font-size: 14px; font-weight: 600; color: var(--c-accent);
    background: none; border: none; padding: 0; cursor: pointer; text-decoration: underline;
  }
  #flb2b-{{ uid }} .flb2b__errors {
    grid-column: 1 / -1; background: color-mix(in srgb, #c0392b 8%, transparent);
    border: 1px solid color-mix(in srgb, #c0392b 35%, transparent); color: #8a1c2b;
    border-radius: var(--r-input); padding: 12px 14px; font-size: 14px; margin-bottom: 4px;
  }
  #flb2b-{{ uid }} .flb2b__errors ul { margin: 6px 0 0; padding-left: 18px; }
  #flb2b-{{ uid }} .flb2b__error-js { color: #b00020; font-size: 13px; display: none; grid-column: 1 / -1; }

  #flb2b-{{ uid }} .flb2b__success { text-align: left; padding: 8px 0; }
  #flb2b-{{ uid }} .flb2b__success h3 { font-size: 22px; font-weight: 600; margin: 14px 0 10px; }
  #flb2b-{{ uid }} .flb2b__success p { font-size: 15px; line-height: 1.6; opacity: .8; margin: 0; }

  @media (max-width: 860px) {
    #flb2b-{{ uid }} .flb2b__wrap { grid-template-columns: 1fr; }
    #flb2b-{{ uid }} .flb2b__media { min-height: 220px; }
    #flb2b-{{ uid }} .flb2b__card { padding: 26px; }
    #flb2b-{{ uid }} .flb2b__grid { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) { #flb2b-{{ uid }} * { transition: none !important; } }
</style>

<section id="flb2b-{{ uid }}" class="flb2b">
  <div class="flb2b__wrap">

    <div class="flb2b__media">
      {%- if s.side_image != blank -%}
        <img src="{{ s.side_image | image_url: width: 1200 }}" alt="" loading="lazy" width="{{ s.side_image.width }}" height="{{ s.side_image.height }}">
      {%- endif -%}
      {%- if s.media_heading != blank or s.media_text != blank -%}
        <div class="flb2b__media-cap">
          {%- if s.eyebrow != blank -%}<p class="flb2b__media-eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
          {%- if s.media_heading != blank -%}<h2>{{ s.media_heading }}</h2>{%- endif -%}
          {%- if s.media_text != blank -%}<p>{{ s.media_text }}</p>{%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="flb2b__card">
      <div class="flb2b__bar"><span></span></div>

      {%- if customer -%}
        {%- comment -%} Inloggad: skicka direkt till katalogen {%- endcomment -%}
        <div class="flb2b__success" data-flb2b-redirect="{{ catalog }}">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
            <circle cx="20" cy="20" r="19" stroke="{{ s.accent_color }}" stroke-width="2"/>
            <path d="M13 20.5l4.5 4.5L27 15" stroke="{{ s.accent_color }}" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <h3>{{ s.logged_in_heading }}</h3>
          <p>{{ s.logged_in_text }}</p>
          <a class="flb2b__btn" href="{{ catalog }}">{{ s.logged_in_button }}</a>
        </div>

      {%- else -%}

        {%- comment -%} ---------- LOGIN ---------- {%- endcomment -%}
        <div class="flb2b__view" data-view="login">
          <p class="flb2b__step">{{ s.login_step }}</p>
          <h2 class="flb2b__h">{{ s.login_heading }}</h2>
          {%- if s.login_subtext != blank -%}<p class="flb2b__sub">{{ s.login_subtext }}</p>{%- endif -%}

          {%- if s.use_hosted_login -%}
            <a class="flb2b__btn" href="{{ routes.account_login_url }}">{{ s.login_button_label }}</a>
            <p class="flb2b__switch">Inte kund än? <a class="flb2b__link" href="{{ routes.account_register_url }}">{{ s.to_register_label }}</a></p>
          {%- else -%}
            {%- form 'customer_login', class: 'flb2b__form flb2b__form--login' -%}
              <div class="flb2b__grid">
                {%- if form.errors -%}
                  <div class="flb2b__errors">{{ form.errors | default_errors }}</div>
                  <span data-flb2b-open="login" hidden></span>
                {%- endif -%}
                <input type="hidden" name="return_url" value="{{ catalog }}">
                <div class="flb2b__field flb2b__field--full">
                  <label for="flb2b-le-{{ uid }}">E-post <span class="req">*</span></label>
                  <input type="email" id="flb2b-le-{{ uid }}" name="customer[email]" autocomplete="email" required>
                </div>
                <div class="flb2b__field flb2b__field--full">
                  <label for="flb2b-lp-{{ uid }}">Lösenord <span class="req">*</span></label>
                  <input type="password" id="flb2b-lp-{{ uid }}" name="customer[password]" autocomplete="current-password" required>
                </div>
                <button type="submit" class="flb2b__btn">{{ s.login_button_label }}</button>
              </div>
            {%- endform -%}
            <p class="flb2b__switch">Inte kund än? <button type="button" class="flb2b__link" data-flb2b-to="register">{{ s.to_register_label }}</button></p>
          {%- endif -%}
        </div>

        {%- comment -%} ---------- REGISTRERING ---------- {%- endcomment -%}
        {%- unless s.use_hosted_login -%}
          <div class="flb2b__view" data-view="register" hidden>
            <p class="flb2b__step">{{ s.register_step }}</p>
            <h2 class="flb2b__h">{{ s.register_heading }}</h2>
            {%- if s.register_subtext != blank -%}<p class="flb2b__sub">{{ s.register_subtext }}</p>{%- endif -%}

            {%- form 'create_customer', class: 'flb2b__form flb2b__form--register' -%}
              {%- if form.posted_successfully? -%}
                <div class="flb2b__success">
                  <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                    <circle cx="20" cy="20" r="19" stroke="{{ s.accent_color }}" stroke-width="2"/>
                    <path d="M13 20.5l4.5 4.5L27 15" stroke="{{ s.accent_color }}" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <h3>{{ s.success_heading }}</h3>
                  <p>{{ success_msg }}</p>
                </div>
              {%- else -%}
                <div class="flb2b__grid">
                  {%- if form.errors -%}
                    <div class="flb2b__errors">{{ form.errors | default_errors }}</div>
                    <span data-flb2b-open="register" hidden></span>
                  {%- endif -%}

                  <div class="flb2b__field flb2b__field--full">
                    <label for="flb2b-co-{{ uid }}">Företagsnamn <span class="req">*</span></label>
                    <input type="text" id="flb2b-co-{{ uid }}" data-note="Företag" required>
                  </div>
                  <div class="flb2b__field">
                    <label for="flb2b-vat-{{ uid }}">Org-/momsnummer <span class="req">*</span></label>
                    <input type="text" id="flb2b-vat-{{ uid }}" data-note="Org/Momsnr" required>
                  </div>
                  <div class="flb2b__field">
                    <label for="flb2b-ph-{{ uid }}">Telefon <span class="req">*</span></label>
                    <input type="tel" id="flb2b-ph-{{ uid }}" data-note="Telefon" autocomplete="tel" required>
                  </div>

                  <div class="flb2b__field flb2b__field--full">
                    <label>Typ av verksamhet</label>
                    <div class="flb2b__pills">
                      {%- assign types = "Livsmedelsbutik, Delikatess / specialbutik, Café / restaurang, Återförsäljare online, Annat" | split: ", " -%}
                      {%- for t in types -%}
                        <label class="flb2b__pill">
                          <input type="radio" name="flb2b_type" value="{{ t }}">
                          <span>{{ t }}</span>
                        </label>
                      {%- endfor -%}
                    </div>
                  </div>

                  <div class="flb2b__field">
                    <label for="flb2b-fn-{{ uid }}">Förnamn <span class="req">*</span></label>
                    <input type="text" id="flb2b-fn-{{ uid }}" name="customer[first_name]" autocomplete="given-name" required>
                  </div>
                  <div class="flb2b__field">
                    <label for="flb2b-ln-{{ uid }}">Efternamn <span class="req">*</span></label>
                    <input type="text" id="flb2b-ln-{{ uid }}" name="customer[last_name]" autocomplete="family-name" required>
                  </div>

                  <div class="flb2b__field flb2b__field--full">
                    <label for="flb2b-re-{{ uid }}">E-post <span class="req">*</span></label>
                    <input type="email" id="flb2b-re-{{ uid }}" name="customer[email]" autocomplete="email" required>
                  </div>

                  <div class="flb2b__field flb2b__field--full">
                    <label for="flb2b-ad-{{ uid }}">Leveransadress <span class="req">*</span></label>
                    <input type="text" id="flb2b-ad-{{ uid }}" data-note="Gatuadress" placeholder="Gata och nummer" required>
                  </div>
                  <div class="flb2b__field">
                    <label for="flb2b-zi-{{ uid }}">Postnummer <span class="req">*</span></label>
                    <input type="text" id="flb2b-zi-{{ uid }}" data-note="Postnummer" required>
                  </div>
                  <div class="flb2b__field">
                    <label for="flb2b-ci-{{ uid }}">Ort <span class="req">*</span></label>
                    <input type="text" id="flb2b-ci-{{ uid }}" data-note="Ort" required>
                  </div>

                  <div class="flb2b__field flb2b__field--full">
                    <label for="flb2b-ms-{{ uid }}">Meddelande (valfritt)</label>
                    <textarea id="flb2b-ms-{{ uid }}" data-note="Meddelande"></textarea>
                  </div>

                  <div class="flb2b__field">
                    <label for="flb2b-pw-{{ uid }}">Lösenord <span class="req">*</span></label>
                    <input type="password" id="flb2b-pw-{{ uid }}" name="customer[password]" autocomplete="new-password" minlength="5" required>
                    <span class="flb2b__hint">Minst 5 tecken.</span>
                  </div>
                  <div class="flb2b__field">
                    <label for="flb2b-pw2-{{ uid }}">Bekräfta lösenord <span class="req">*</span></label>
                    <input type="password" id="flb2b-pw2-{{ uid }}" autocomplete="new-password" minlength="5" required>
                  </div>

                  {%- if s.show_marketing -%}
                    <label class="flb2b__check">
                      <input type="checkbox" name="customer[accepts_marketing]" value="true">
                      <span>Ja, jag vill få nyheter och erbjudanden från Finsk Lakrits.</span>
                    </label>
                  {%- endif -%}

                  <p class="flb2b__error-js" data-flb2b-error>Lösenorden matchar inte.</p>

                  <input type="hidden" name="customer[tags]" value="{{ apply_tag }}">
                  <textarea name="customer[note]" data-flb2b-note hidden></textarea>

                  <button type="submit" class="flb2b__btn">{{ s.register_button_label }}</button>
                </div>
              {%- endif -%}
            {%- endform -%}
            <p class="flb2b__switch">Har du redan ett konto? <button type="button" class="flb2b__link" data-flb2b-to="login">{{ s.to_login_label }}</button></p>
          </div>
        {%- endunless -%}

      {%- endif -%}
    </div>

  </div>

  <script>
    (function () {
      var root = document.getElementById('flb2b-{{ uid }}');
      if (!root) return;

      // Inloggad -> skicka till katalogen
      var rd = root.querySelector('[data-flb2b-redirect]');
      if (rd && rd.getAttribute('data-flb2b-redirect')) {
        window.location.replace(rd.getAttribute('data-flb2b-redirect'));
        return;
      }

      // Växla login/registrering
      function setView(v) {
        root.querySelectorAll('.flb2b__view').forEach(function (el) {
          el.hidden = el.getAttribute('data-view') !== v;
        });
      }
      root.querySelectorAll('[data-flb2b-to]').forEach(function (btn) {
        btn.addEventListener('click', function () { setView(btn.getAttribute('data-flb2b-to')); });
      });

      // Öppna rätt vy vid fel/hash
      if (root.querySelector('[data-flb2b-open="register"]') || location.hash === '#registrera') {
        setView('register');
      } else {
        setView('login');
      }

      // Registreringsformulär: validera + bygg kundnotering
      var reg = root.querySelector('.flb2b__form--register');
      if (reg) {
        var note = reg.querySelector('[data-flb2b-note]');
        var errEl = reg.querySelector('[data-flb2b-error]');
        var pw = document.getElementById('flb2b-pw-{{ uid }}');
        var pw2 = document.getElementById('flb2b-pw2-{{ uid }}');
        reg.addEventListener('submit', function (e) {
          if (pw && pw2 && pw.value !== pw2.value) {
            e.preventDefault();
            if (errEl) errEl.style.display = 'block';
            pw2.focus();
            return;
          }
          if (errEl) errEl.style.display = 'none';
          var lines = ['ÅTERFÖRSÄLJARANSÖKAN'];
          reg.querySelectorAll('[data-note]').forEach(function (el) {
            var val = (el.value || '').trim();
            if (val) lines.push(el.getAttribute('data-note') + ': ' + val);
          });
          var t = reg.querySelector('input[name="flb2b_type"]:checked');
          if (t) lines.push('Verksamhet: ' + t.value);
          if (note) note.value = lines.join('\n');
        });
      }
    })();
  </script>
</section>

{% schema %}
{
  "name": "Återförsäljarportal",
  "tag": "section",
  "class": "section-flb2b",
  "settings": [
    { "type": "header", "content": "Bild (vänster)" },
    { "type": "image_picker", "id": "side_image", "label": "Bild" },
    { "type": "text", "id": "eyebrow", "label": "Etikett", "default": "Återförsäljare" },
    { "type": "text", "id": "media_heading", "label": "Rubrik på bild", "default": "Finsk premiumlakrits för din butik" },
    { "type": "textarea", "id": "media_text", "label": "Text på bild", "default": "Logga in för att se grossistpriser och beställa direkt." },

    { "type": "header", "content": "Logga in" },
    { "type": "text", "id": "login_step", "label": "Liten etikett", "default": "Återförsäljare" },
    { "type": "text", "id": "login_heading", "label": "Rubrik", "default": "Logga in" },
    { "type": "textarea", "id": "login_subtext", "label": "Undertext", "default": "Logga in på ditt återförsäljarkonto för att se grossistpriser och lägga order." },
    { "type": "text", "id": "login_button_label", "label": "Knapptext", "default": "Logga in" },
    { "type": "text", "id": "to_register_label", "label": "Länk till registrering", "default": "Registrera dig" },

