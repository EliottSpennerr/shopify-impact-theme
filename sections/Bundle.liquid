    { "type": "text", "id": "heading", "label": "Rubrik", "default": "Bygg din egen mix" },
    { "type": "text", "id": "subheading", "label": "Underrubrik", "default": "Välj minst 8 favoriter och få 10% rabatt på hela ordern" },
    { "type": "text", "id": "text_quick_add", "label": "Aria: snabblägg", "default": "Tryck för att lägga till" },
    { "type": "text", "id": "text_progress_remaining", "label": "Progress (före)", "default": "{remaining} till för {discount}% rabatt", "info": "{remaining} = antal kvar, {discount} = rabattprocent" },
    { "type": "text", "id": "text_progress_complete", "label": "Progress (klar)", "default": "✓ {discount}% rabatt aktiverad — {count} produkter valda", "info": "{discount} = rabattprocent, {count} = antal" },
    { "type": "text", "id": "text_selected", "label": "\"valda\"", "default": "valda" },
    { "type": "text", "id": "text_you_save", "label": "Besparingstext", "default": "Du sparar {amount}", "info": "{amount} = belopp" },
    { "type": "text", "id": "text_cta_before", "label": "CTA (0 valda)", "default": "Välj minst {min} st", "info": "{min} = minsta antal" },
    { "type": "text", "id": "text_cta_remaining", "label": "CTA (pågående)", "default": "Välj {remaining} till", "info": "{remaining} = antal kvar" },
    { "type": "text", "id": "text_cta_go_to_cart", "label": "CTA (checkout)", "default": "Gå till kassan — {price}", "info": "{price} = pris med rabatt" },
    { "type": "text", "id": "text_decrease", "label": "Aria: minska", "default": "Minska antal" },
    { "type": "text", "id": "text_increase", "label": "Aria: öka", "default": "Öka antal" },
    { "type": "header", "content": "Kategorifilter" },
    { "type": "text", "id": "text_filter_all", "label": "Alla-knapp", "default": "Alla" },
    { "type": "text", "id": "text_no_results", "label": "Inga resultat", "default": "Inga produkter matchar ditt filter." },
    { "type": "header", "content": "Slutsålda produkter" },
    { "type": "select", "id": "soldout_behavior", "label": "Hantering", "options": [{ "value": "hide", "label": "Dölj helt" }, { "value": "show", "label": "Visa (gråad)" }], "default": "hide" },
    { "type": "text", "id": "text_soldout", "label": "Slutsåld-text", "default": "Slutsåld" },
    { "type": "header", "content": "Färger" },
    { "type": "color", "id": "color_background", "label": "Bakgrund (sektion)", "default": "#faf8f5" },
    { "type": "color", "id": "color_card_bg", "label": "Bakgrund (kort)", "default": "#ffffff" },
    { "type": "color", "id": "color_text", "label": "Text", "default": "#1a1a1a" },
    { "type": "color", "id": "color_text_muted", "label": "Text (sekundär)", "default": "#6b6b6b" },
    { "type": "color", "id": "color_button", "label": "Knappar & CTA", "default": "#1a2e44" },
    { "type": "color", "id": "color_button_hover", "label": "Knappar hover", "default": "#2a3e54" },
    { "type": "color", "id": "color_success", "label": "Rabatt & framgång", "default": "#2d7a4f" },
    { "type": "color", "id": "color_border", "label": "Kanter", "default": "#e5e2dd" },
    { "type": "color", "id": "color_badge_bg", "label": "Badge bakgrund", "default": "#2d7a4f" },
    { "type": "color", "id": "color_badge_text", "label": "Badge text", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Kategori",
      "settings": [
        { "type": "text", "id": "label", "label": "Knapptext", "default": "Saltlakrits" },
        { "type": "collection", "id": "collection", "label": "Kollektion" }
      ]
    }
