{%- comment -%}
IMPLEMENTATION NOTE: Impact header with all the menu is an extremely complex piece of code. Due to requirements from design
team, we had to cover over hundred of potential combinations. As a consequence, this part (and all the menu snippets) are
extremely sensitive code that should (if possible) not be touched unless you have spend enough time to study and understand
the underlying logic of the menu.
{%- endcomment -%}

{%- if section.settings.show_country_selector and localization.available_countries.size > 1 -%}
  {%- assign will_show_country_selector = true -%}
{%- endif -%}

{%- if section.settings.show_locale_selector and localization.available_languages.size > 1 -%}
  {%- assign will_show_locale_selector = true -%}
{%- endif -%}

<style>
  :root {
    --sticky-header-enabled: {%- if section.settings.enable_sticky -%}1{% else %}0{% endif %};
  }

  #shopify-section-{{ section.id }} {
    --header-grid-template: "logo search secondary-nav" / auto 1fr auto;
    --header-padding-block: {% if section.settings.reduce_padding %}var(--spacing-3){% else %}var(--spacing-4-5){% endif %};
    --header-background-opacity: {{ section.settings.background_opacity | divided_by: 100.0 }};
    --header-background-blur-radius: {{ section.settings.background_blur_radius }}px;
    --header-transparent-text-color: {{ section.settings.transparent_header_text_color.rgb }};

    /* Searchbar: storlek och farg fran schemainstaellningar */
    --search-text-size: {{ section.settings.search_text_size }}px;
    --search-text-color: {{ section.settings.search_text_color }};

    /* Desktop nav-rad: storlek och farg fran schemainstaellningar */
    --desktop-nav-text-size: {{ section.settings.desktop_nav_text_size }}px;
    --desktop-nav-text-color: {{ section.settings.desktop_nav_text_color }};

    {%- if section.settings.logo != blank -%}
      --header-logo-width: {{ section.settings.logo_mobile_max_width }}px;
      --header-logo-height: {{ section.settings.logo_mobile_max_width | divided_by: section.settings.logo.aspect_ratio | round }}px;
    {%- endif -%}

    position: {% if section.settings.enable_sticky %}sticky{% else %}relative{% endif %};
    top: 0;
    z-index: 10;
  }

  {%- if section.settings.enable_sticky -%}
    .shopify-section--announcement-bar ~ #shopify-section-{{ section.id }} {
      top: calc(var(--sticky-announcement-bar-enabled, 0) * var(--announcement-bar-height, 0px));
    }
  {%- endif -%}

  {%- if section.settings.opening_from == 'left' -%}
    @media screen and (max-width: 699px) {
      .navigation-drawer {
        --drawer-content-max-height: calc(100vh - (var(--spacing-2) * 2));
      }
    }
  {%- endif -%}

  @media screen and (min-width: 700px) {
    #shopify-section-{{ section.id }} {
      {%- if section.settings.logo != blank -%}
        --header-logo-width: {{ section.settings.logo_max_width }}px;
        --header-logo-height: {{ section.settings.logo_max_width | divided_by: section.settings.logo.aspect_ratio | round }}px;
      {%- endif -%}

      --header-padding-block: {% if section.settings.reduce_padding %}var(--spacing-6){% else %}var(--spacing-8-5){% endif %};
    }
  }

  /* Logo + hamburger wrapper */
  .header__logo-with-hamburger {
    grid-area: logo;
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .header__logo-with-hamburger .header__logo {
    flex-shrink: 0;
  }

  /* Search field in center */
  .header__search-center {
    grid-area: search;
    display: flex;
    align-items: center;
    padding: 0 16px;
  }

  .header__search-center-form {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #E5E6E7;
    border-radius: 100px;
    padding: 10px 18px;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    position: relative; /* ankrar predictive-search-dropdown */
  }

  .header__search-center-form svg {
    flex-shrink: 0;
    opacity: 0.45;
    color: var(--search-text-color, currentColor);
  }

  .header__search-center-input {
    border: none;
    background: none;
    outline: none;
    font-size: var(--search-text-size, 14px);
    color: var(--search-text-color, currentColor);
    width: 100%;
  }

  .header__search-center-input::placeholder {
    color: var(--search-text-color, #999);
    opacity: 0.55;
  }

  /* Hide the old search icon on desktop since search is now inline */
  @media screen and (min-width: 750px) {
    .header__search-icon-hide {
      display: none !important;
    }
  }

  /* ─────────────────────────────────────────────────────────────────
     PREDICTIVE SEARCH DROPDOWN
     Visas under sokpillret nar anvandaren skriver minst 2 tecken.
     Absolut-positionerad inuti formen, vilket innebar att den arver
     formens bredd (600px max pa desktop, 100% pa mobil) automatiskt.
     ───────────────────────────────────────────────────────────────── */
  .predictive-search-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12), 0 2px 6px rgba(0, 0, 0, 0.04);
    max-height: 70vh;
    overflow-y: auto;
    z-index: 50;
  }

  .predictive-search-dropdown[hidden] {
    display: none;
  }

  .predictive-search__section {
    padding: 10px 0 12px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .predictive-search__section:last-of-type {
    border-bottom: none;
  }

  .predictive-search__heading {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.55;
    padding: 6px 20px 8px;
  }

  .predictive-search__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .predictive-search__item {
    margin: 0;
    padding: 0;
  }

  .predictive-search__link {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 8px 20px;
    text-decoration: none;
    color: inherit;
    transition: background-color 0.12s ease;
  }

  .predictive-search__link:hover,
  .predictive-search__link:focus-visible {
    background-color: rgba(0, 0, 0, 0.04);
    outline: none;
  }

  .predictive-search__image {
    width: 52px;
    height: 52px;
    border-radius: 8px;
    object-fit: cover;
    background: #f5f5f5;
    flex-shrink: 0;
  }

  .predictive-search__image--placeholder {
    background: #f0f0f0;
  }

  .predictive-search__meta {
    flex: 1;
    min-width: 0;
  }

  .predictive-search__title {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.3;
    color: #111;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .predictive-search__price {
    font-size: 13px;
    color: #555;
    margin-top: 2px;
  }

  .predictive-search__link--simple {
    padding: 9px 20px;
    font-size: 14px;
    color: #222;
  }

  .predictive-search__view-all {
    display: block;
    padding: 14px 20px;
    background: rgba(0, 0, 0, 0.03);
    font-size: 13px;
    font-weight: 500;
    text-align: center;
    text-decoration: none;
    color: #111;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    transition: background-color 0.12s ease;
  }

  .predictive-search__view-all:hover {
    background: rgba(0, 0, 0, 0.06);
  }

  .predictive-search__empty {
    padding: 28px 20px;
    text-align: center;
    font-size: 14px;
    color: #555;
  }

  .predictive-search__loading {
    padding: 20px;
    text-align: center;
    font-size: 13px;
    color: #777;
  }

  /* Mobile: dropdown ar i row 2 (full bredd), justera skugga och radie */
  @media screen and (max-width: 749px) {
    .predictive-search-dropdown {
      border-radius: 0 0 16px 16px;
      box-shadow: 0 14px 30px rgba(0, 0, 0, 0.15);
      max-height: calc(100vh - 180px);
    }
  }

  /* ─────────────────────────────────────────────────────────────────
     DESKTOP NAVIGATION ROW — visas enbart pa desktop (>=750px)
     En andra rad under header-wrappern med utvalda sidor som
     horisontella textlankar. Ingen avdelare, bara lankar direkt.
     ───────────────────────────────────────────────────────────────── */
  .header__desktop-nav {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .header__desktop-nav {
      display: block;
      background-color: rgb(var(--color-background, 255 255 255));
      overflow: hidden;
       position: relative; /* NY RAD */
    z-index: 1;         /* NY RAD - explicit lagre an formens z-index: 5 */
    }

    .header__desktop-nav-list {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      list-style: none;
      background: rgb(var(--background) / var(--header-background-opacity));
      margin: 0;
      padding: 0 0 var(--spacing-3, 12px) 130px;
    }

    .header__desktop-nav-link {
      display: inline-block;
      padding: 2px 34px 2px 0;
      font-size: var(--desktop-nav-text-size, 14px);
      font-weight: 500;
      text-decoration: none;
      color: var(--desktop-nav-text-color, currentColor);
      opacity: 0.85;
      transition: opacity 0.15s ease;
      white-space: nowrap;
      position: relative;
    }

    .header__desktop-nav-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: calc(100% - 24px);
      height: 1px;
      background-color: var(--desktop-nav-text-color, currentColor);
      transform: scaleX(0);
      transform-origin: left center;
      transition: transform 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .header__desktop-nav-link:hover {
      opacity: 1;
    }

    .header__desktop-nav-link:hover::after {
      transform: scaleX(1);
    }
  }

  /* ─────────────────────────────────────────────────────────────────
     MOBILE LAYOUT (749px): 2-rad header
     Rad 1: hamburger (vanster) | logga (AKTA MITTEN) | kundvagn (hoger)
     Rad 2: sokfalt (full bredd, visuellt avgransat)

     TEKNIK: display: contents pa .header__logo-with-hamburger gor att
     hamburgaren och loggan behandlas som direkta grid-barn i wrappern.
     grid-template-columns: 1fr auto 1fr placerar loggan i en auto-kolumn
     flankerad av lika stora 1fr-kolumner - matematisk skarmcentrering
     oavsett bredd pa hamburger eller kundvagn. DOM, aria och JS paverkas
     inte av display: contents eftersom elementet finns kvar i tradet.
     ───────────────────────────────────────────────────────────────── */
  @media screen and (max-width: 749px) {

    #shopify-section-{{ section.id }} .header__wrapper {
      display: grid;
      grid-template-areas:
        "hamburger logo cart"
        "search    search search";
      grid-template-columns: 1fr auto 1fr;
      grid-template-rows: auto auto;
      align-items: center;
      padding-bottom: 0px;
    }

    #shopify-section-{{ section.id }} .header__logo-with-hamburger {
      display: contents;
    }

    #shopify-section-{{ section.id }} .header__logo-with-hamburger > button {
      grid-area: hamburger;
      justify-self: start;
      align-self: center;
    }

    #shopify-section-{{ section.id }} .header__logo-with-hamburger .header__logo {
      grid-area: logo;
      justify-self: center;
      align-self: center;
      margin: 0;
    }

    #shopify-section-{{ section.id }} .header__secondary-nav {
      grid-area: cart;
      justify-self: end;
      align-self: center;
    }

    #shopify-section-{{ section.id }} .header__search-center {
      grid-area: search;
      padding: 8px 12px 14px;
      border-top: 1px solid rgba(0, 0, 0, 0.07);
    }

    #shopify-section-{{ section.id }} .header__search-center .header__search-center-form {
      max-width: 100%;
    }
  }
</style>

<height-observer variable="header">
  <store-header class="header" {% if section.settings.hide_on_scroll %}hide-on-scroll="100"{% endif %} {% if section.settings.enable_sticky %}sticky{% endif %}>
    <div class="header__wrapper">

      {%- comment -%}
      LOGO + HAMBURGER — left grid area
      {%- endcomment -%}

      {%- capture logo_content -%}
        {%- if section.settings.logo -%}
          {%- capture sizes -%}{{ section.settings.logo_max_width }}px{%- endcapture -%}
          {%- capture widths -%}{{ section.settings.logo_max_width | times: 2 | at_most: section.settings.logo.width }}, {{ section.settings.logo_max_width | times: 3 | at_most: section.settings.logo.width }}{%- endcapture -%}
          <span class="sr-only">{{ shop.name }}</span>
          {{- section.settings.logo | image_url: width: section.settings.logo.width | image_tag: sizes: sizes, widths: widths, class: 'header__logo-image' -}}
          {%- if section.settings.transparent_logo -%}
            {{- section.settings.transparent_logo | image_url: width: section.settings.transparent_logo.width | image_tag: sizes: sizes, widths: widths, class: 'header__logo-image header__logo-image--transparent' -}}
          {%- endif -%}
        {%- else -%}
          <span class="header__logo-text h4">{{ shop.name }}</span>
        {%- endif -%}
      {%- endcapture -%}

      <div class="header__logo-with-hamburger">
        {%- if request.page_type == 'index' -%}
          <h1 class="header__logo" style="margin:0;">
            <a href="{{ routes.root_url }}">{{ logo_content }}</a>
          </h1>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="header__logo">{{ logo_content }}</a>
        {%- endif -%}

        <button type="button" class="tap-area {% if section.settings.layout != 'drawer' %}lg:hidden{% endif %}" aria-controls="header-sidebar-menu">
          <span class="sr-only">{{ 'header.general.open_menu' | t }}</span>
          {%- render 'icon' with 'hamburger' -%}
        </button>
      </div>

      {%- comment -%}
      SEARCH — center grid area (desktop) / full-width row 2 (mobile)
      Inkluderar nu predictive-search dropdown som visas vid input.
      {%- endcomment -%}

      <div class="header__search-center">
        <form action="{{ routes.search_url }}" method="get" class="header__search-center-form" role="search">
          <input type="hidden" name="type" value="product">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input
            class="header__search-center-input"
            type="search"
            name="q"
            placeholder="{{ section.settings.search_placeholder | default: 'Sök produkter...' }}"
            aria-label="{{ 'general.search.search' | t }}"
            aria-autocomplete="list"
            aria-controls="predictive-search-dropdown-{{ section.id }}"
            autocomplete="off"
          >

          {%- comment -%} Predictive search dropdown — fylls dynamiskt av JS {%- endcomment -%}
          <div
            id="predictive-search-dropdown-{{ section.id }}"
            class="predictive-search-dropdown"
            role="listbox"
            aria-label="Sökförslag"
            hidden
          ></div>
        </form>
      </div>

      {%- comment -%}
      SECONDARY NAV AREA — unchanged from original
      {%- endcomment -%}

      <div class="header__secondary-nav">
        {%- if section.settings.header != 'drawer' and section.settings.secondary_menu.links.size > 0 -%}
          <nav class="header__link-list" role="navigation">
            <ul class="contents">
              {%- for link in section.settings.secondary_menu.links -%}
                <li>
                  <a href="{{ link.url }}" class="bold link-faded-reverse">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </nav>
        {%- endif -%}

        <div class="header__icon-list">
          {%- if section.settings.show_country_selector and localization.available_countries.size > 1 -%}
            <div class="hidden md:block shrink-0">
              {%- render 'localization-selector', type: 'country', show_country_name: section.settings.show_country_name, show_country_flag: section.settings.show_country_flag, popover_vertical_position: 'end' -%}
            </div>
          {%- endif -%}

          {%- if section.settings.show_locale_selector and localization.available_languages.size > 1 -%}
            <div class="hidden md:block shrink-0">
              {%- render 'localization-selector', type: 'locale', popover_vertical_position: 'end' -%}
            </div>
          {%- endif -%}

          <a href="{{ routes.search_url }}" class="hidden tap-area sm:block header__search-icon-hide" aria-controls="search-drawer">
            <span class="sr-only">{{ 'header.general.open_search' | t }}</span>
            {%- render 'icon' with 'search' -%}
          </a>

          {%- if shop.customer_accounts_enabled -%}
            <a href="{{ routes.account_url }}" class="hidden tap-area sm:block">
              <span class="sr-only">{{ 'header.general.open_account' | t }}</span>
              {%- render 'icon' with 'account' -%}
            </a>
          {%- endif -%}

          <a href="{{ routes.cart_url }}" data-no-instant class="relative tap-area" {% if settings.cart_type != 'page' and request.page_type != 'cart' %}aria-controls="cart-drawer"{% endif %}>
            <span class="sr-only">{{ 'header.general.open_cart' | t }}</span>
            {%- render 'icon' with 'cart' -%}

            <div class="header__cart-count">
              <cart-count class="count-bubble {% if cart.item_count == 0 %}opacity-0{% endif %}" aria-hidden="true">
                {{- cart.item_count -}}
              </cart-count>
            </div>
          </a>
        </div>
      </div>

    </div>

    {%- comment -%}
    DESKTOP NAVIGATION ROW — syns endast pa desktop (>= 750px)
    Renderar utvalda sidor som horisontella textlankar under huvudraden.
    {%- endcomment -%}

    {%- if section.settings.desktop_nav_menu != blank and section.settings.desktop_nav_menu.links.size > 0 -%}
      <nav class="header__desktop-nav" aria-label="{{ 'header.general.nav_label' | t | default: 'Primär navigation' }}">
        <ul class="header__desktop-nav-list">
          {%- for link in section.settings.desktop_nav_menu.links -%}
            <li>
              <a href="{{ link.url }}"
                 class="header__desktop-nav-link"
                 {% if link.current %}aria-current="page"{% endif %}>
                {{- link.title -}}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

  </store-header>
</height-observer>

{%- comment -%}
  NAVIGATION MENU DRAWER — unchanged from original
{%- endcomment -%}

{%- assign main_menu = section.settings.sidebar_menu | default: section.settings.menu -%}
{%- assign secondary_menu = section.settings.secondary_menu -%}

{%- if main_menu.links.size > 0 or secondary_menu.links.size > 0 -%}
  <navigation-drawer mobile-opening="{{ section.settings.opening_from }}" open-from="left" id="header-sidebar-menu" class="navigation-drawer drawer {% if section.settings.layout != 'drawer' %}lg:hidden{% endif %}" {% if request.design_mode %}handle-section-events{% endif %}>
    <button is="close-button" aria-label="{{ 'general.accessibility.close' | t | escape }}" {%- if section.settings.opening_from == 'bottom' -%}class="sm-max:hidden"{%- endif -%}>
      {%- render 'icon' with 'close', width: 19, height: 19 -%}
    </button>

    {%- render 'navigation-panel',
      is_mega_menu: false,
      main_menu: main_menu,
      secondary_menu: secondary_menu,
      mobile_opening: section.settings.opening_from,
      layout: section.settings.layout,
      show_social_media: section.settings.show_social_media,
      show_country_selector: section.settings.show_country_selector,
      show_country_name: section.settings.show_country_name,
      show_country_flag: section.settings.show_country_flag,
      show_locale_selector: section.settings.show_locale_selector -%}
  </navigation-drawer>
{%- endif -%}

<script>
  (function () {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    function updateHeaderHeight() {
      document.documentElement.style.setProperty('--header-height', Math.round(section.clientHeight) + 'px');
    }

    updateHeaderHeight();

    if (typeof ResizeObserver !== 'undefined') {
      new ResizeObserver(updateHeaderHeight).observe(section);
    }
  })();
</script>

{%- comment -%}
  PREDICTIVE SEARCH SCRIPT
  Lyssnar pa input i sokfaltet, anropar Shopify /search/suggest.json
  och renderar produkter, kategorier och bloggartiklar i dropdown.
  Debouncad 200ms, AbortController for att avbryta gamla requests.
{%- endcomment -%}
<script>
  (function () {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    var form = section.querySelector('.header__search-center-form');
    var input = section.querySelector('.header__search-center-input');
    var dropdown = section.querySelector('.predictive-search-dropdown');
    if (!form || !input || !dropdown) return;

    var MIN_CHARS = 2;
    var DEBOUNCE_MS = 200;
    var debounceTimer = null;
    var currentController = null;

    // Valuta- och lokalformatering hamtas fran Shopify-objektet via Liquid
    var currencyCode = '{{ cart.currency.iso_code | default: shop.currency }}';
    var localeCode = '{{ request.locale.iso_code | default: "sv-SE" | replace: "_", "-" }}';
    var searchUrl = '{{ routes.search_url }}';
    var predictiveUrl = '{{ routes.predictive_search_url }}';

    var currencyFormatter;
    try {
      currencyFormatter = new Intl.NumberFormat(localeCode, {
        style: 'currency',
        currency: currencyCode,
        maximumFractionDigits: 2
      });
    } catch (e) {
      currencyFormatter = null;
    }

    function formatPrice(cents) {
      if (cents == null) return '';
      var amount = cents / 100;
      if (currencyFormatter) return currencyFormatter.format(amount);
      return amount.toFixed(2) + ' ' + currencyCode;
    }

    function escapeHtml(str) {
      if (str == null) return '';
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function openDropdown() {
      dropdown.hidden = false;
      input.setAttribute('aria-expanded', 'true');
    }

    function closeDropdown() {
      dropdown.hidden = true;
      input.setAttribute('aria-expanded', 'false');
    }

    function renderLoading() {
      dropdown.innerHTML = '<div class="predictive-search__loading">Söker…</div>';
      openDropdown();
    }

    function renderEmpty(query) {
      dropdown.innerHTML = '<div class="predictive-search__empty">Inga träffar för "' + escapeHtml(query) + '"</div>'
        + '<a href="' + searchUrl + '?q=' + encodeURIComponent(query) + '" class="predictive-search__view-all">Visa alla resultat</a>';
      openDropdown();
    }

    function renderResults(data, query) {
      var results = (data && data.resources && data.resources.results) || {};
      var products = (results.products || []).slice(0, 6);
      var collections = (results.collections || []).slice(0, 4);
      var articles = (results.articles || []).slice(0, 4);

      if (!products.length && !collections.length && !articles.length) {
        renderEmpty(query);
        return;
      }

      var html = '';

      if (products.length) {
        html += '<div class="predictive-search__section">';
        html += '<div class="predictive-search__heading">Produkter</div>';
        html += '<ul class="predictive-search__list" role="presentation">';
        products.forEach(function (product) {
          var img = '';
          if (product.featured_image && product.featured_image.url) {
            img = product.featured_image.url;
          } else if (product.image) {
            img = product.image;
          }

          var price = '';
          if (typeof product.price === 'number') {
            price = formatPrice(product.price);
          } else if (typeof product.price === 'string' && product.price.length) {
            // Shopify kan ibland returnera strang — visa direkt
            price = product.price;
          }

          html += '<li class="predictive-search__item" role="option">';
          html += '<a href="' + escapeHtml(product.url) + '" class="predictive-search__link">';
          if (img) {
            html += '<img class="predictive-search__image" src="' + escapeHtml(img) + '" alt="" loading="lazy" width="52" height="52">';
          } else {
            html += '<div class="predictive-search__image predictive-search__image--placeholder"></div>';
          }
          html += '<div class="predictive-search__meta">';
          html += '<div class="predictive-search__title">' + escapeHtml(product.title) + '</div>';
          if (price) html += '<div class="predictive-search__price">' + price + '</div>';
          html += '</div></a></li>';
        });
        html += '</ul></div>';
      }

      if (collections.length) {
        html += '<div class="predictive-search__section">';
        html += '<div class="predictive-search__heading">Kategorier</div>';
        html += '<ul class="predictive-search__list" role="presentation">';
        collections.forEach(function (collection) {
          html += '<li class="predictive-search__item" role="option">';
          html += '<a href="' + escapeHtml(collection.url) + '" class="predictive-search__link predictive-search__link--simple">';
          html += escapeHtml(collection.title);
          html += '</a></li>';
        });
        html += '</ul></div>';
      }

      if (articles.length) {
        html += '<div class="predictive-search__section">';
        html += '<div class="predictive-search__heading">Bloggartiklar</div>';
        html += '<ul class="predictive-search__list" role="presentation">';
        articles.forEach(function (article) {
          html += '<li class="predictive-search__item" role="option">';
          html += '<a href="' + escapeHtml(article.url) + '" class="predictive-search__link predictive-search__link--simple">';
          html += escapeHtml(article.title);
          html += '</a></li>';
        });
        html += '</ul></div>';
      }

      html += '<a href="' + searchUrl + '?q=' + encodeURIComponent(query) + '" class="predictive-search__view-all">Visa alla resultat för "' + escapeHtml(query) + '"</a>';

      dropdown.innerHTML = html;
      openDropdown();
    }

    function fetchResults(query) {
      if (currentController) {
        try { currentController.abort(); } catch (e) {}
      }
      currentController = (typeof AbortController !== 'undefined') ? new AbortController() : null;

      var url = predictiveUrl + '.json'
        + '?q=' + encodeURIComponent(query)
        + '&resources[type]=product,collection,article'
        + '&resources[limit]=6'
        + '&resources[options][unavailable_products]=last';

      var fetchOpts = currentController ? { signal: currentController.signal } : {};

      fetch(url, fetchOpts)
        .then(function (res) {
          if (!res.ok) throw new Error('Predictive search request failed: ' + res.status);
          return res.json();
        })
        .then(function (data) {
          renderResults(data, query);
        })
        .catch(function (err) {
          if (err && err.name === 'AbortError') return;
          console.warn('Predictive search error:', err);
        });
    }

    function handleInput() {
      var query = input.value.trim();

      clearTimeout(debounceTimer);

      if (query.length < MIN_CHARS) {
        closeDropdown();
        dropdown.innerHTML = '';
        return;
      }

      debounceTimer = setTimeout(function () {
        fetchResults(query);
      }, DEBOUNCE_MS);
    }

    input.addEventListener('input', handleInput);

    input.addEventListener('focus', function () {
      var query = input.value.trim();
      if (query.length >= MIN_CHARS && dropdown.innerHTML.trim().length > 0) {
        openDropdown();
      }
    });

    // Klick utanfor sokomradet — stang dropdown
    document.addEventListener('click', function (e) {
      if (!form.contains(e.target)) {
        closeDropdown();
      }
    });

    // Escape — stang dropdown och blurra input
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !dropdown.hidden) {
        closeDropdown();
        input.blur();
      }
    });
  })();
</script>

