{%- if section.settings.show_filters and search.filters.size > 0 -%}
  {%- assign show_filters = true -%}
{%- else -%}
  {%- assign show_filters = false -%}
{%- endif -%}

{%- assign active_filters = search.filters | where: 'active_values' -%}

{%- capture search_form -%}
  <form class="main-search-form" action="{{ routes.search_url }}" method="get" role="search">
    {%- comment -%}
      type=product bevaras sa att produktsokningens pagination och filter
      fungerar korrekt. Rakningar och resultat for artiklar/sidor hämtas
      separat via Predictive Search API i JavaScript.
    {%- endcomment -%}
    <input type="hidden" name="type" value="product">

    <div class="v-stack gap-6 sm:gap-12">
      <div class="search-input">
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'search.general.search_placeholder' | t }}" autocomplete="off" autocorrect="off" spellcheck="false" aria-label="{{ 'search.general.title' | t | escape }}">
        <button type="submit">{%- render 'icon' with 'search' -%}</button>
      </div>

      {%- unless search.results_count > 0 -%}
        <div class="justify-self-center">
          {%- assign button_content = 'search.general.title' | t -%}
          {%- render 'button', type: 'submit', content: button_content, size: 'xl' -%}
        </div>
      {%- endunless -%}
    </div>
  </form>
{%- endcapture -%}

<style>
  {%- assign card_blends = false -%}

  {%- unless settings.background != 'rgba(0,0,0,0)' and settings.product_card_background != 'rgba(0,0,0,0)' and settings.background != settings.product_card_background -%}
    {%- assign card_blends = true -%}
  {%- endunless -%}

  #shopify-section-{{ section.id }} {
    --product-list-gap: {% if section.settings.products_per_row_mobile == '2' %}{% if card_blends %}var(--product-list-row-gap){% endif %} var(--spacing-2){% else %}var(--product-list-row-gap) var(--product-list-column-gap){% endif %};
    --product-list-items-per-row: {{ section.settings.products_per_row_mobile | times: 1 }};
    --product-list-grid: auto-flow dense / repeat(var(--product-list-items-per-row), minmax(0, 1fr));
    --content-over-media-gap: var(--spacing-8);

    --search-title-size: {{ section.settings.search_title_size }}px;
    --search-title-color: {{ section.settings.search_title_color }};
    --pill-active-bg: {{ section.settings.pill_active_color }};
    --pill-active-text: {{ section.settings.pill_active_text_color }};
  }

  @media screen and (min-width: 700px) {
    #shopify-section-{{ section.id }} {
      --product-list-gap: var(--product-list-row-gap) var(--product-list-column-gap);
      --product-list-items-per-row: 2;
    }
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} {
      --product-list-items-per-row: {% if section.settings.filter_layout == 'sidebar' %}2{% else %}{{ section.settings.products_per_row_desktop | at_most: 3 }}{% endif %};
    }
  }

  @media screen and (min-width: 1200px) {
    #shopify-section-{{ section.id }} {
      --product-list-items-per-row: {% if section.settings.filter_layout == 'sidebar' %}{{ section.settings.products_per_row_desktop | at_most: 3 }}{% else %}{{ section.settings.products_per_row_desktop }}{% endif %};
    }
  }

  @media screen and (min-width: 1400px) {
    #shopify-section-{{ section.id }} {
      --product-list-items-per-row: {{ section.settings.products_per_row_desktop }};
    }
  }

  /* ─── Soktitel ─────────────────────────────────────────────────── */
  .search-results-title {
    font-size: var(--search-title-size, 2.5rem);
    color: var(--search-title-color, currentColor);
    text-align: center;
    font-weight: 700;
    line-height: 1.15;
  }

  /* ─── Type-filter pills ─────────────────────────────────────────── */
  .search-type-pills {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .search-type-pill {
    display: inline-flex;
    align-items: center;
    padding: 10px 22px;
    border-radius: 100px;
    border: 2px solid var(--pill-active-bg, #1a2e44);
    background: transparent;
    color: var(--pill-active-bg, #1a2e44);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease;
    white-space: nowrap;
    font-family: inherit;
    line-height: 1;
  }

  .search-type-pill[aria-selected="true"] {
    background: var(--pill-active-bg, #1a2e44);
    color: var(--pill-active-text, #ffffff);
  }

  .search-type-pill:hover:not([aria-selected="true"]) {
    background: color-mix(in srgb, var(--pill-active-bg, #1a2e44) 8%, transparent);
  }

  /* ─── Resultatsektioner ─────────────────────────────────────────── */
  .search-type-section {
    display: none;
  }

  .search-type-section.is-active {
    display: block;
  }

  /* Artikel- och sida-lista */
  .search-secondary-results {
    list-style: none;
    margin: var(--spacing-8, 32px) 0 0;
    padding: 0;
    max-width: 760px;
  }

  .search-secondary-result {
    padding: 16px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .search-secondary-result:last-child {
    border-bottom: none;
  }

  .search-secondary-result__type {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.45;
    margin: 0 0 4px;
  }

  .search-secondary-result__title {
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    color: currentColor;
    display: block;
  }

  .search-secondary-result__title:hover {
    text-decoration: underline;
  }

  .search-secondary-result__excerpt {
    font-size: 14px;
    opacity: 0.6;
    margin: 4px 0 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-empty-type {
    text-align: center;
    padding: 48px 0;
    opacity: 0.4;
    font-size: 15px;
  }

  /* Laddnings-placeholder for sekundara tabbar */
  .search-secondary-loading {
    text-align: center;
    padding: 32px 0;
    opacity: 0.4;
    font-size: 14px;
  }
</style>

<div class="container">
  {%- if search.performed and search.results_count > 0 or active_filters.size > 0 -%}
    <div class="page-spacer">
      <div class="v-stack gap-6 sm:gap-8">

        <h1 class="search-results-title">
          {{- section.settings.search_title_prefix -}}&nbsp;&ldquo;{{- search.terms -}}&rdquo;
        </h1>

        {{- search_form -}}

        {%- comment -%}
          Pills. Produkter-rakningen kommer fran Liquid (korrekt, server-side).
          Artiklar/Sidor fylls i av JavaScript via Predictive Search API.
          data-search-query anvands av JS for att bygga API-anropet.
        {%- endcomment -%}
        <div class="search-type-pills"
             role="tablist"
             data-search-query="{{ search.terms | escape }}">

          <button class="search-type-pill"
                  role="tab"
                  aria-selected="true"
                  aria-controls="search-section-products"
                  data-search-tab="products">
            {{ section.settings.pill_label_products }}
            (<span id="count-products">{{ search.results_count }}</span>)
          </button>

          <button class="search-type-pill"
                  role="tab"
                  aria-selected="false"
                  aria-controls="search-section-articles"
                  data-search-tab="articles">
            {{ section.settings.pill_label_articles }}
            (<span id="count-articles">…</span>)
          </button>

          <button class="search-type-pill"
                  role="tab"
                  aria-selected="false"
                  aria-controls="search-section-pages"
                  data-search-tab="pages">
            {{ section.settings.pill_label_pages }}
            (<span id="count-pages">…</span>)
          </button>

        </div>
      </div>

      {%- comment -%} ── PRODUKTER (server-side, full pagination + filter) ── {%- endcomment -%}
      <div id="search-section-products" class="search-type-section is-active" role="tabpanel">
        {%- paginate search.results by section.settings.products_per_page -%}
          <div class="collection {% if show_filters %}collection--filters-{{ section.settings.filter_layout | escape }}{% endif %}">
            {%- if show_filters or section.settings.show_sort_by -%}
              <facet-drawer header-bordered id="facets-drawer" class="facets-drawer drawer" open-from="left">
                <p class="h5" slot="title">{{ 'collection.faceting.filters' | t }}</p>
                {%- render 'facets-vertical', results: search, show_filters: true, show_sort_by: section.settings.show_sort_by, update_on_change: false -%}
              </facet-drawer>

              {%- if section.settings.filter_layout == 'horizontal' -%}
                {%- render 'collection-top-bar', results: search, show_filters: show_filters, show_active_filters: show_filters, show_sort_by: section.settings.show_sort_by -%}
              {%- else -%}
                {%- render 'collection-top-bar', results: search, show_filters: false, show_active_filters: show_filters, show_sort_by: section.settings.show_sort_by -%}
              {%- endif -%}

              <facet-floating-filter class="facets__floating-filter md:hidden">
                {%- assign filter_label = 'collection.faceting.filter_and_sort' | t -%}
                {%- render 'button', size: 'xl', content: filter_label, icon: 'filter', style: 'fill', background: settings.text_color, text_color: settings.background, aria_controls: 'facets-drawer' -%}
              </facet-floating-filter>
            {%- endif -%}

            {%- if show_filters and section.settings.filter_layout == 'sidebar' -%}
              <div class="collection__facets">
                <safe-sticky class="collection__facets-scroller">
                  {%- render 'facets-vertical', results: search, show_filters: true, show_sort_by: false, update_on_change: true -%}
                </safe-sticky>
              </div>
            {%- endif -%}

            <div class="collection__results">
              {%- if search.results_count == 0 -%}
                <div class="empty-state">
                  <div class="empty-state__icon-wrapper">
                    {%- render 'icon' with 'picto-stop', width: 32, height: 32, stroke_width: 1 -%}
                    <span class="count-bubble count-bubble--lg">0</span>
                  </div>
                  <div class="prose">
                    <p class="h5">{{ 'collection.faceting.no_results' | t }}</p>
                    {%- assign button_content = 'collection.faceting.clear_filters' | t -%}
                    {%- render 'button', href: collection.url, is: 'facet-link', size: 'xl', content: button_content -%}
                  </div>
                </div>
              {%- else -%}
                <div class="v-stack gap-6">
                  <div class="v-stack gap-4 md:hidden">
                    {%- render 'active-facets', results: search -%}
                  </div>
                  <reveal-items selector=".product-list > *">
                    <product-list class="product-list" role="region" aria-live="polite">
                      {%- assign product_results = search.results | where: 'object_type', 'product' -%}
                      {%- for product in product_results -%}
                        {%- render 'product-card', product: product, stacked: true, show_badges: true -%}
                      {%- endfor -%}
                    </product-list>
                  </reveal-items>
                </div>
              {%- endif -%}
            </div>

            {%- render 'pagination', paginate: paginate, facet: true, class: 'collection__pagination' -%}
          </div>
        {%- endpaginate -%}
      </div>



  {%- else -%}
    <div class="empty-state">
      <h1 class="search-results-title">
        {%- if search.performed -%}
          {{- 'search.general.no_results' | t -}}
        {%- else -%}
          {{- 'search.general.title' | t -}}
        {%- endif -%}
      </h1>
      {{- search_form -}}
    </div>
  {%- endif -%}
</div>

<script>
(function () {
  /* ── Tab switching ────────────────────────────────────────────── */
  var pills    = document.querySelectorAll('[data-search-tab]');
  var sections = document.querySelectorAll('.search-type-section');

  pills.forEach(function (pill) {
    pill.addEventListener('click', function () {
      var target = pill.dataset.searchTab;
      pills.forEach(function (p) { p.setAttribute('aria-selected', 'false'); });
      pill.setAttribute('aria-selected', 'true');
      sections.forEach(function (s) {
        s.classList.toggle('is-active', s.id === 'search-section-' + target);
      });
    });
  });

  /* ── Hämta artiklar och sidor via Predictive Search API ──────── */
  var pillsWrapper = document.querySelector('[data-search-query]');
  if (!pillsWrapper) return;

  var query = pillsWrapper.dataset.searchQuery;
  if (!query) return;

  /* Etiketter fran Liquid for att anvandas i den genererade listan */
  var labels = {
    articles: {{ section.settings.pill_label_articles | json }},
    pages:    {{ section.settings.pill_label_pages    | json }}
  };

  /* Tomplatta for tom-state */
  var emptyHtml = '<p class="search-empty-type">{{ "collection.faceting.no_results" | t }}</p>';

  function buildList(items, labelKey) {
    if (!items || items.length === 0) return emptyHtml;

    var html = '<ul class="search-secondary-results">';
    items.forEach(function (item) {
      var excerpt = item.body ? item.body.replace(/<[^>]+>/g, '').substring(0, 160) : '';
      html += '<li class="search-secondary-result">'
            + '<p class="search-secondary-result__type">' + labels[labelKey] + '</p>'
            + '<a href="' + item.url + '" class="search-secondary-result__title">' + item.title + '</a>'
            + (excerpt ? '<p class="search-secondary-result__excerpt">' + excerpt + '</p>' : '')
            + '</li>';
    });
    html += '</ul>';
    return html;
  }

  fetch(
    '/search/suggest.json'
    + '?q=' + encodeURIComponent(query)
    + '&resources[type]=article,page'
    + '&resources[limit]=50'
  )
  .then(function (res) { return res.json(); })
  .then(function (data) {
    var results  = (data.resources && data.resources.results) || {};
    var articles = results.articles || [];
    var pages    = results.pages    || [];

    /* Uppdatera pill-rakningar */
    document.getElementById('count-articles').textContent = articles.length;
    document.getElementById('count-pages').textContent    = pages.length;

    /* Rendera resultatlistor */
    document.getElementById('search-section-articles').innerHTML = buildList(articles, 'articles');
    document.getElementById('search-section-pages').innerHTML    = buildList(pages, 'pages');
  })
  .catch(function () {
    /* Vid fel: visa 0 och tomt */
    document.getElementById('count-articles').textContent = '0';
    document.getElementById('count-pages').textContent    = '0';
    document.getElementById('search-section-articles').innerHTML = emptyHtml;
    document.getElementById('search-section-pages').innerHTML    = emptyHtml;
  });
})();
</script>

{% schema %}
{
  "name": "Search",
  "class": "shopify-section--main-search",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Search title"
    },
    {
      "type": "text",
      "id": "search_title_prefix",
      "label": "Title prefix text",
      "default": "Visar resultat för",
      "info": "Text som visas fore sokordet i rubriken, t.ex. 'Visar resultat for' eller 'Showing results for'."
    },
    {
      "type": "range",
      "id": "search_title_size",
      "min": 20,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 40
    },
    {
      "type": "color",
      "id": "search_title_color",
      "label": "Title color",
      "default": "#1a2e44"
    },
    {
      "type": "header",
      "content": "Type filter pills"
    },
    {
      "type": "color",
      "id": "pill_active_color",
      "label": "Active pill background",
      "default": "#1a2e44"
    },
    {
      "type": "color",
      "id": "pill_active_text_color",
      "label": "Active pill text",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "pill_label_products",
      "label": "Products pill label",
      "default": "Produkter"
    },
    {
      "type": "text",
      "id": "pill_label_articles",
      "label": "Articles pill label",
      "default": "Artiklar"
    },
    {
      "type": "text",
      "id": "pill_label_pages",
      "label": "Pages pill label",
      "default": "Sidor"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 50,
      "step": 1,
      "default": 24
    },
    {
      "type": "select",
      "id": "products_per_row_mobile",
      "label": "Products per row (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "min": 2,
      "max": 5,
      "id": "products_per_row_desktop",
      "label": "Products per row (desktop)",
      "info": "For best results, limit to 4 when using sidebar filtering. On small screen size, products per row is limited to 2 (with sidebar) or 3 (without sidebar) to maximize readability",
      "default": 3
    },
    {
      "type": "header",
      "content": "Filters & sort"
    },
    {
      "type": "select",
      "id": "filter_layout",
      "label": "Desktop layout",
      "options": [
        { "value": "sidebar", "label": "Sidebar" },
        { "value": "horizontal", "label": "Horizontal" },
        { "value": "drawer", "label": "Drawer" }
      ],
      "default": "sidebar"
    },
    {
      "type": "checkbox",
      "id": "show_sort_by",
      "label": "Show sort by",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show filters",
      "info": "[Customize filters](/admin/menus)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_filter_group_name",
      "label": "Show group name",
      "info": "Group name will be shown inside selected filters.",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_color_swatch",
      "label": "Show filter color swatch",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_empty_filter_values",
      "label": "Show empty filter values",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_filter_values_count",
      "label": "Show filter values count",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "open_first_filter_group",
      "label": "Open first group by default",
      "default": false
    }
  ]
}
{% endschema %}
