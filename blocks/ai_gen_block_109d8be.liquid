{% doc %}
  @prompt
    Hero carousel with physical drag - slides follow cursor/finger in real time, snap on release.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-carousel-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    height: {{ block.settings.section_height_mobile }}px;
    overflow: hidden;
    touch-action: pan-y;
  }

  @media screen and (min-width: 750px) {
    .ai-hero-carousel-{{ ai_gen_id }} {
      height: {{ block.settings.section_height_desktop }}px;
    }
  }

  .ai-hero-carousel__track-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
    height: 100%;
    will-change: transform;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }

  .ai-hero-carousel__track-{{ ai_gen_id }}.is-snapping {
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .ai-hero-carousel__track-{{ ai_gen_id }}.is-dragging {
    cursor: grabbing;
  }

  .ai-hero-carousel__slide-{{ ai_gen_id }} {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-hero-carousel__slide-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    draggable: false;
  }

  .ai-hero-carousel__slide-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-carousel__slide-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-carousel__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    pointer-events: none;
  }

  .ai-hero-carousel__content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px 80px;
    pointer-events: none;
  }

  .ai-hero-carousel__content-wrapper-{{ ai_gen_id }} {
    max-width: 800px;
    width: 100%;
    text-align: center;
    pointer-events: auto;
  }

  .ai-hero-carousel__content-wrapper-{{ ai_gen_id }}--left {
    text-align: left;
  }

  .ai-hero-carousel__eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size_mobile }}px;
    color: {{ block.settings.eyebrow_color }};
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  @media screen and (min-width: 750px) {
    .ai-hero-carousel__eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_size_desktop }}px;
    }
  }

  .ai-hero-carousel__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size_mobile }}px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_button_spacing }}px;
    line-height: 1.2;
  }

  @media screen and (min-width: 750px) {
    .ai-hero-carousel__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_desktop }}px;
    }
  }

  .ai-hero-carousel__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 40px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ settings.button_border_radius }}px;
    font-size: {{ block.settings.button_size_mobile }}px;
    font-weight: 600;
    transition: opacity 0.3s ease;
    border: none;
    cursor: pointer;
  }

  @media screen and (min-width: 750px) {
    .ai-hero-carousel__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_size_desktop }}px;
    }
  }

  .ai-hero-carousel__button-{{ ai_gen_id }}:hover {
    opacity: 0.9;
  }

  .ai-hero-carousel__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_background }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: opacity 0.3s ease;
    {% if block.settings.arrow_style == 'circle' %}
      width: {{ block.settings.arrow_size }}px;
      height: {{ block.settings.arrow_size }}px;
      border-radius: 50%;
    {% else %}
      width: {{ block.settings.arrow_size }}px;
      height: {{ block.settings.arrow_size | times: 1.5 }}px;
      border-radius: 4px;
    {% endif %}
  }

  {% unless block.settings.show_arrows %}
    .ai-hero-carousel__nav-{{ ai_gen_id }} {
      display: none;
    }
  {% endunless %}

  .ai-hero-carousel__nav-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-hero-carousel__nav-{{ ai_gen_id }}--prev {
    left: 20px;
  }

  .ai-hero-carousel__nav-{{ ai_gen_id }}--next {
    right: 20px;
  }

  .ai-hero-carousel__nav-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.arrow_size }}px * 0.5);
    height: calc({{ block.settings.arrow_size }}px * 0.5);
    stroke: {{ block.settings.arrow_color }};
    stroke-width: 2;
  }

  .ai-hero-carousel__dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 60px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 10;
    pointer-events: auto;
  }

  .ai-hero-carousel__dot-{{ ai_gen_id }} {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.5);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .ai-hero-carousel__dot-{{ ai_gen_id }}.active {
    background-color: rgba(255, 255, 255, 1);
    transform: scale(1.2);
  }

  .ai-hero-carousel__dot-{{ ai_gen_id }}:hover {
    background-color: rgba(255, 255, 255, 0.8);
  }
{% endstyle %}

<hero-carousel-{{ ai_gen_id }} class="ai-hero-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-carousel__track-{{ ai_gen_id }}" id="track-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign slide_image_key = 'slide_' | append: i | append: '_image'
        assign slide_eyebrow_key = 'slide_' | append: i | append: '_eyebrow'
        assign slide_title_key = 'slide_' | append: i | append: '_title'
        assign slide_button_text_key = 'slide_' | append: i | append: '_button_text'
        assign slide_button_link_key = 'slide_' | append: i | append: '_button_link'

        assign slide_image = block.settings[slide_image_key]
        assign slide_eyebrow = block.settings[slide_eyebrow_key]
        assign slide_title = block.settings[slide_title_key]
        assign slide_button_text = block.settings[slide_button_text_key]
        assign slide_button_link = block.settings[slide_button_link_key]
      %}

      {% if slide_image != blank or slide_eyebrow != blank or slide_title != blank %}
        <div class="ai-hero-carousel__slide-{{ ai_gen_id }}" data-slide="{{ forloop.index }}">
          {% if slide_image %}
            <img
              src="{{ slide_image | image_url: width: 1200 }}"
              srcset="{{ slide_image | image_url: width: 600 }} 600w, {{ slide_image | image_url: width: 900 }} 900w, {{ slide_image | image_url: width: 1200 }} 1200w, {{ slide_image | image_url: width: 1800 }} 1800w, {{ slide_image | image_url: width: 2400 }} 2400w"
              sizes="100vw"
              alt="{{ slide_image.alt | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              fetchpriority="{% if forloop.first %}high{% else %}low{% endif %}"
              width="{{ slide_image.width }}"
              height="{{ slide_image.height }}"
              class="ai-hero-carousel__slide-image-{{ ai_gen_id }}"
              draggable="false"
            >
          {% else %}
            <div class="ai-hero-carousel__slide-placeholder-{{ ai_gen_id }}">
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          <div class="ai-hero-carousel__overlay-{{ ai_gen_id }}"></div>

          <div class="ai-hero-carousel__content-{{ ai_gen_id }}">
            <div class="ai-hero-carousel__content-wrapper-{{ ai_gen_id }} {% if block.settings.layout == 'left' %}ai-hero-carousel__content-wrapper-{{ ai_gen_id }}--left{% endif %}">
              {% if slide_eyebrow != blank %}
                <div class="ai-hero-carousel__eyebrow-{{ ai_gen_id }}">{{ slide_eyebrow }}</div>
              {% endif %}

              {% if slide_title != blank %}
                <h2 class="ai-hero-carousel__title-{{ ai_gen_id }}">{{ slide_title }}</h2>
              {% endif %}

              {% if block.settings.show_button and slide_button_text != blank %}
                <a href="{{ slide_button_link }}" class="ai-hero-carousel__button-{{ ai_gen_id }}">
                  {{ slide_button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <button class="ai-hero-carousel__nav-{{ ai_gen_id }} ai-hero-carousel__nav-{{ ai_gen_id }}--prev" aria-label="Previous slide">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>

  <button class="ai-hero-carousel__nav-{{ ai_gen_id }} ai-hero-carousel__nav-{{ ai_gen_id }}--next" aria-label="Next slide">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>

  <div class="ai-hero-carousel__dots-{{ ai_gen_id }}"></div>
</hero-carousel-{{ ai_gen_id }}>

<script>
(function() {
  class HeroCarousel{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.currentSlide = 0;
      this.slideCount = 0;
      this.autoplayInterval = null;
      this.autoplayEnabled = false;
      this.autoplayDelay = 5000;

      // Drag state
      this.isDragging = false;
      this.startX = 0;
      this.currentX = 0;
      this.dragDelta = 0;
      this.snapThreshold = 80; // px needed to trigger slide change
    }

    connectedCallback() {
      this.track = this.querySelector('.ai-hero-carousel__track-{{ ai_gen_id }}');
      this.slides = Array.from(this.querySelectorAll('.ai-hero-carousel__slide-{{ ai_gen_id }}'));
      this.prevButton = this.querySelector('.ai-hero-carousel__nav-{{ ai_gen_id }}--prev');
      this.nextButton = this.querySelector('.ai-hero-carousel__nav-{{ ai_gen_id }}--next');
      this.dotsContainer = this.querySelector('.ai-hero-carousel__dots-{{ ai_gen_id }}');

      if (this.slides.length === 0) return;

      this.slideCount = this.slides.length;
      this.autoplayEnabled = {{ block.settings.autoplay | json }};
      this.autoplayDelay = {{ block.settings.autoplay_delay | json }} * 1000;

      this.createDots();
      this.setupArrows();
      this.setupDrag();
      this.setPosition(0, false);

      if (this.autoplayEnabled && this.slideCount > 1) {
        this.startAutoplay();
      }
    }

    disconnectedCallback() {
      this.stopAutoplay();
      window.removeEventListener('mousemove', this._mousemove);
      window.removeEventListener('mouseup', this._mouseup);
    }

    // ---- Position ----
    setPosition(x, animate) {
      if (animate) {
        this.track.classList.add('is-snapping');
        this.track.addEventListener('transitionend', () => {
          this.track.classList.remove('is-snapping');
        }, { once: true });
      }
      this.track.style.transform = `translateX(${x}px)`;
    }

    getBaseX() {
      return -(this.currentSlide * this.offsetWidth);
    }

    // ---- Slide logic ----
    goToSlide(index, animate = true) {
      this.currentSlide = Math.max(0, Math.min(index, this.slideCount - 1));
      this.setPosition(this.getBaseX(), animate);
      this.updateDots();
    }

    nextSlide() {
      this.goToSlide((this.currentSlide + 1) % this.slideCount);
    }

    previousSlide() {
      this.goToSlide((this.currentSlide - 1 + this.slideCount) % this.slideCount);
    }

    // ---- Dots ----
    createDots() {
      this.slides.forEach((_, index) => {
        const dot = document.createElement('button');
        dot.classList.add('ai-hero-carousel__dot-{{ ai_gen_id }}');
        if (index === 0) dot.classList.add('active');
        dot.setAttribute('aria-label', 'Go to slide ' + (index + 1));
        dot.addEventListener('click', () => {
          this.stopAutoplay();
          this.goToSlide(index);
          if (this.autoplayEnabled) this.startAutoplay();
        });
        this.dotsContainer.appendChild(dot);
      });
      this.dots = Array.from(this.dotsContainer.querySelectorAll('.ai-hero-carousel__dot-{{ ai_gen_id }}'));
    }

    updateDots() {
      this.dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === this.currentSlide);
      });
    }

    // ---- Arrows ----
    setupArrows() {
      this.prevButton.addEventListener('click', () => {
        this.stopAutoplay();
        this.previousSlide();
        if (this.autoplayEnabled) this.startAutoplay();
      });
      this.nextButton.addEventListener('click', () => {
        this.stopAutoplay();
        this.nextSlide();
        if (this.autoplayEnabled) this.startAutoplay();
      });
    }

    // ---- Drag ----
    setupDrag() {
      // Mouse
      this.track.addEventListener('mousedown', (e) => {
        if (e.target.closest('a, button')) return;
        this.dragStart(e.clientX);
        e.preventDefault();
      });

      this._mousemove = (e) => {
        if (!this.isDragging) return;
        this.dragMove(e.clientX);
      };

      this._mouseup = (e) => {
        if (!this.isDragging) return;
        this.dragEnd(e.clientX);
      };

      window.addEventListener('mousemove', this._mousemove);
      window.addEventListener('mouseup', this._mouseup);

      // Touch
      this.track.addEventListener('touchstart', (e) => {
        if (e.target.closest('a, button')) return;
        this.dragStart(e.touches[0].clientX);
      }, { passive: true });

      this.track.addEventListener('touchmove', (e) => {
        if (!this.isDragging) return;
        this.dragMove(e.touches[0].clientX);
      }, { passive: true });

      this.track.addEventListener('touchend', (e) => {
        if (!this.isDragging) return;
        this.dragEnd(e.changedTouches[0].clientX);
      });
    }

    dragStart(x) {
      this.isDragging = true;
      this.startX = x;
      this.dragDelta = 0;
      this.track.classList.add('is-dragging');
      this.stopAutoplay();
    }

    dragMove(x) {
      if (!this.isDragging) return;
      this.dragDelta = x - this.startX;

      // Resist at edges
      if (
        (this.currentSlide === 0 && this.dragDelta > 0) ||
        (this.currentSlide === this.slideCount - 1 && this.dragDelta < 0)
      ) {
        this.dragDelta = this.dragDelta * 0.2; // rubber-band resistance
      }

      this.setPosition(this.getBaseX() + this.dragDelta, false);
    }

    dragEnd(x) {
      if (!this.isDragging) return;
      this.isDragging = false;
      this.track.classList.remove('is-dragging');

      const delta = x - this.startX;

      if (Math.abs(delta) >= this.snapThreshold) {
        if (delta < 0 && this.currentSlide < this.slideCount - 1) {
          this.goToSlide(this.currentSlide + 1);
        } else if (delta > 0 && this.currentSlide > 0) {
          this.goToSlide(this.currentSlide - 1);
        } else {
          // At edge — snap back
          this.goToSlide(this.currentSlide);
        }
      } else {
        // Not enough — snap back
        this.goToSlide(this.currentSlide);
      }

      if (this.autoplayEnabled) this.startAutoplay();
    }

    // ---- Autoplay ----
    startAutoplay() {
      this.stopAutoplay();
      if (this.autoplayEnabled && this.slideCount > 1) {
        this.autoplayInterval = setInterval(() => this.nextSlide(), this.autoplayDelay);
      }
    }

    stopAutoplay() {
      if (this.autoplayInterval) {
        clearInterval(this.autoplayInterval);
        this.autoplayInterval = null;
      }
    }
  }

  if (!customElements.get('hero-carousel-{{ ai_gen_id }}')) {
    customElements.define('hero-carousel-{{ ai_gen_id }}', HeroCarousel{{ ai_gen_id }});
  }
})();
</script>

{% schema %}
{
  "name": "Hero carousel",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Content layout",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left", "label": "Left" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show CTA button",
      "default": false
    },
    {
      "type": "range",
      "id": "section_height_mobile",
      "label": "Height on mobile",
      "min": 300,
      "max": 700,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "section_height_desktop",
      "label": "Height on desktop",
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 650
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Navigation arrows"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "select",
      "id": "arrow_style",
      "label": "Arrow style",
      "options": [
        { "value": "circle", "label": "Circle" },
        { "value": "square", "label": "Square" }
      ],
      "default": "circle"
    },
    {
      "type": "range",
      "id": "arrow_size",
      "label": "Arrow size",
      "min": 32,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "arrow_background",
      "label": "Arrow background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow icon color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "eyebrow_size_mobile",
      "label": "Eyebrow size on mobile",
      "min": 10,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "eyebrow_size_desktop",
      "label": "Eyebrow size on desktop",
      "min": 12,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Title size on mobile",
      "min": 24,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Title size on desktop",
      "min": 32,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "title_button_spacing",
      "label": "Space between title and button",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_size_mobile",
      "label": "Button size on mobile",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_size_desktop",
      "label": "Button size on desktop",
      "min": 14,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "label": "Autoplay delay",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "header",
      "content": "Slide 1"
    },
    {
      "type": "image_picker",
      "id": "slide_1_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "slide_1_eyebrow",
      "label": "Eyebrow text",
      "default": "New Collection"
    },
    {
      "type": "text",
      "id": "slide_1_title",
      "label": "Title",
      "default": "Discover Our Latest Styles"
    },
    {
      "type": "text",
      "id": "slide_1_button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "slide_1_button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Slide 2"
    },
