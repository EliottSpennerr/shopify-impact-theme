{% doc %}
  @prompt
    Create a collection grid section that displays a row of collection icons with labels. Each item shows a collection image cropped into a customizable shape, with the collection title displayed in bold below it. The section should support 4 to 8 items in a single scrollable row. In the theme customizer, each item should have a collection picker so the image and title are pulled automatically from the selected collection. Add a shape selector per item — or globally for all items — with options for: circle, rounded square, organic blob, pill, hexagon, and square. The image should fill the shape with object-fit cover. Below each image, show the collection name in bold, centered, with a customizable text color and font size. The section background should be a soft off-white or light cream. At the top of the section, add a decorative curved or rounded border-radius divider that visually connects this section to the hero banner above it — the top edge of the section background should curve upward or have a large border-radius so it overlaps and blends into the section above. All colors including background, text color, and shape background tint should be editable in the customizer., Gör så att jag kan välja om sektionen ska vara centrrerad eller left. Ta bort hover funktionen lägg bara hover funktion på texten. samt gör så jag kan ändra storlek på font och färg.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}

.ai-collection-grid-container-{{ ai_gen_id }} {
  scrollbar-width: none!important;
}

.ai-collection-grid-container-{{ ai_gen_id }}::-webkit-scrollbar {
  display: none!important;
}
  .ai-collection-grid-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.background_color }};
    padding: 60px 20px 60px;
    margin-top: -40px;
    border-radius: {{ block.settings.top_curve_radius }}px {{ block.settings.top_curve_radius }}px 0 0;
    width: 100%;
    display: block;
  }

  .ai-collection-grid-container-{{ ai_gen_id }} {
    max-width: 1600px;
    margin: 0 auto;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: {{ block.settings.text_color }}33 transparent;
  }

  .ai-collection-grid-container-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 8px;
  }

  .ai-collection-grid-container-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: transparent;
  }

  .ai-collection-grid-container-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background-color: {{ block.settings.text_color }}33;
    border-radius: 4px;
  }

  .ai-collection-grid-row-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.item_spacing }}px;
    padding: 0 20px;
    min-width: min-content;
    {% if block.settings.alignment == 'center' %}
      justify-content: center;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-collection-grid-item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-decoration: none;
  }

  .ai-collection-grid-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    overflow: hidden;
    background-color: {{ block.settings.shape_background_tint }};
  }

  .ai-collection-grid-image-wrapper-{{ ai_gen_id }}.shape-circle {
    border-radius: 50%;
  }

  .ai-collection-grid-image-wrapper-{{ ai_gen_id }}.shape-rounded-square {
    border-radius: 20%;
  }

  .ai-collection-grid-image-wrapper-{{ ai_gen_id }}.shape-square {
    border-radius: 0;
  }

  .ai-collection-grid-image-wrapper-{{ ai_gen_id }}.shape-pill {
    border-radius: 999px;
  }

  .ai-collection-grid-image-wrapper-{{ ai_gen_id }}.shape-hexagon {
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  }

  .ai-collection-grid-image-wrapper-{{ ai_gen_id }}.shape-blob {
    border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
  }

  .ai-collection-grid-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-collection-grid-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #e0e0e0;
  }

  .ai-collection-grid-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-collection-grid-title-{{ ai_gen_id }} {
    font-weight: {{ block.settings.text_weight }};
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    text-align: center;
    margin: 0;
    max-width: {{ block.settings.image_size }}px;
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .ai-collection-grid-item-{{ ai_gen_id }}:hover .ai-collection-grid-title-{{ ai_gen_id }} {
    color: {{ block.settings.text_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-collection-grid-{{ ai_gen_id }} {
      padding: 40px 10px 40px;
      margin-top: -30px;
    }

    .ai-collection-grid-row-{{ ai_gen_id }} {
      padding: 0 10px;
    }

    .ai-collection-grid-image-wrapper-{{ ai_gen_id }} {
      width: calc({{ block.settings.image_size }}px * 0.8);
      height: calc({{ block.settings.image_size }}px * 0.8);
    }

    .ai-collection-grid-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
      max-width: calc({{ block.settings.image_size }}px * 0.8);
    }
  }
{% endstyle %}

<collection-grid-{{ ai_gen_id }} class="ai-collection-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-grid-container-{{ ai_gen_id }}">
    <div class="ai-collection-grid-row-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign shape_key = 'shape_' | append: i
          assign collection = block.settings[collection_key]
          assign item_shape = block.settings[shape_key]
          
          if block.settings.use_global_shape
            assign item_shape = block.settings.global_shape
          endif
        %}

        {% if collection != blank %}
          <a
            href="{{ collection.url }}"
            class="ai-collection-grid-item-{{ ai_gen_id }}"
            aria-label="{{ collection.title }}"
          >
            <div class="ai-collection-grid-image-wrapper-{{ ai_gen_id }} shape-{{ item_shape }}">
              {% if collection.featured_image %}
                <img
                  src="{{ collection.featured_image | image_url: width: 400 }}"
                  alt="{{ collection.featured_image.alt | default: collection.title | escape }}"
                  class="ai-collection-grid-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              {% else %}
                <div class="ai-collection-grid-placeholder-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <h3 class="ai-collection-grid-title-{{ ai_gen_id }}">{{ collection.title }}</h3>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</collection-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.container = this.querySelector('.ai-collection-grid-container-{{ ai_gen_id }}');
        this.setupScrollBehavior();
      }

      setupScrollBehavior() {
        if (!this.container) return;

        let isDown = false;
        let startX;
        let scrollLeft;

        this.container.addEventListener('mousedown', (e) => {
          isDown = true;
          this.container.style.cursor = 'grabbing';
          startX = e.pageX - this.container.offsetLeft;
          scrollLeft = this.container.scrollLeft;
        });

        this.container.addEventListener('mouseleave', () => {
          isDown = false;
          this.container.style.cursor = 'grab';
        });

        this.container.addEventListener('mouseup', () => {
          isDown = false;
          this.container.style.cursor = 'grab';
        });

        this.container.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.container.offsetLeft;
          const walk = (x - startX) * 2;
          this.container.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('collection-grid-{{ ai_gen_id }}', CollectionGrid{{ ai_gen_id }});
  })();
</script>

