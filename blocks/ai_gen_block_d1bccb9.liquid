{% doc %}
  @prompt
    Create a modern hero header section with a rectangular layout and slightly rounded corners (not fully rounded). The section should have clear whitespace around it so it feels separated from the page edges.
    
    Use a background image that fills the entire container (cover), aligned slightly to the right, with food or lifestyle visuals. Add a subtle dark or green overlay if needed to improve text readability.
    
    Place text content on the left side:
    
    Large bold headline
    Smaller descriptive paragraph underneath
    
    Ensure:
    
    Strong contrast between text and background
    Clean spacing and padding inside the container
    Responsive design (image scales well on mobile)
    The overall feel should be minimal, modern, and premium
    
    Style details:
    
    Border-radius: small (e.g. 12–16px)
    Generous padding inside (top/bottom/left/right)
    Margin around the container to create whitespace from page edges
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}

  .ai-hero-header-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: {{ block.settings.container_margin }}px auto;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    position: relative;
    min-height: {{ block.settings.min_height }}px;
      background-color: #ffffff!important;

  }

  .ai-hero-header__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-header__background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ block.settings.image_position }};
  }

  .ai-hero-header__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e5e5e5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-header__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.3;
  }

  .ai-hero-header__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-hero-header__content-wrapper-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    display: flex;
    align-items: center;
    min-height: {{ block.settings.min_height }}px;
  }

  .ai-hero-header__content-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-header__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-header__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    margin: 0;
    color: {{ block.settings.text_color }};
    opacity: 0.95;
  }

  .ai-hero-header__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    background-color: rgba(255, 255, 255, 0.9);
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-header-{{ ai_gen_id }} {
      margin: {{ block.settings.container_margin | times: 0.5 }}px auto;
      min-height: {{ block.settings.min_height | times: 0.7 }}px;
    }

    .ai-hero-header__content-wrapper-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.6 }}px {{ block.settings.padding_horizontal | times: 0.6 }}px;
      min-height: {{ block.settings.min_height | times: 0.7 }}px;
    }

    .ai-hero-header__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-hero-header__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-hero-header__content-{{ ai_gen_id }} {
      max-width: 100%;
    }
  }
{% endstyle %}

<hero-header-{{ ai_gen_id }}
  class="ai-hero-header-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-hero-header__background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-header__background-placeholder-{{ ai_gen_id }}">
        {{ 'lifestyle-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  {% if block.settings.overlay_opacity > 0 %}
    <div class="ai-hero-header__overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-hero-header__content-wrapper-{{ ai_gen_id }}">
    <div class="ai-hero-header__content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h1 class="ai-hero-header__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h1>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-hero-header__text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}
    </div>
  </div>

  {% if block.settings.background_image == blank %}
    <div class="ai-hero-header__empty-state-{{ ai_gen_id }}">
      Next, add a background image
    </div>
  {% endif %}
</hero-header-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Hero header",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Premium Swedish Licorice"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Discover our carefully curated selection of authentic Finnish and Swedish confectionery, crafted with tradition and quality.</p>"
    },
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        {
          "value": "left center",
          "label": "Left"
        },
        {
          "value": "center center",
          "label": "Center"
        },
        {
          "value": "right center",
          "label": "Right"
        }
      ],
      "default": "right center"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#1a3a2e"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Description size",
      "min": 14,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Space below heading",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 300,
      "max": 700,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "container_margin",
      "label": "Margin around container",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Padding top/bottom",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding left/right",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 95
    }
  ],
  "presets": [
    {
      "name": "Hero header"
    }
  ]
}
{% endschema %}